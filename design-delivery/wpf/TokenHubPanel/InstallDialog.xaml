<Window x:Class="TokenHubPanel.InstallDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="联想 TokenHub"
        FontFamily="Microsoft YaHei"
        FontSize="14"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        Topmost="True"
        MouseDown="Window_MouseDown">
    <Window.Resources>
        <DropShadowEffect x:Key="InstallWindowShadow"
                          BlurRadius="21"
                          ShadowDepth="2"
                          Direction="270"
                          Color="#000000"
                          Opacity="0.22" />

        <Style x:Key="CaptionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="4" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0A000000" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryInstallButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="200" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="#005FB8"
                                BorderBrush="#14FFFFFF"
                                BorderThickness="1"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0067C0" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#004C99" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.72" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryInstallButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Foreground" Value="#E5000000" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="#B3FFFFFF"
                                BorderBrush="#10000000"
                                BorderThickness="1"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E6FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Win11CheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E5000000" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Border x:Name="CheckBoxBorder"
                                    Width="20"
                                    Height="20"
                                    CornerRadius="4"
                                    Background="#005FB8"
                                    BorderBrush="#005FB8"
                                    BorderThickness="1"
                                    Margin="2,0,0,0"
                                    VerticalAlignment="Top">
                                    <TextBlock x:Name="CheckGlyph"
                                               Text="&#xE73E;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="12"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                            </Border>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="CheckBoxBorder" Property="Background" Value="#00FFFFFF" />
                                <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="#99000000" />
                                <Setter TargetName="CheckGlyph" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="#005FB8" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CheckBoxBorder" Property="Background" Value="#004C99" />
                                <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="#004C99" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="CheckBoxBorder" Property="Opacity" Value="0.45" />
                                <Setter Property="Foreground" Value="#66000000" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="WindowFrame"
            Width="560"
            Height="400"
            CornerRadius="7"
            Background="#F3F3F3"
            BorderBrush="#66757575"
            BorderThickness="1"
            Effect="{StaticResource InstallWindowShadow}"
            Margin="32">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Height="48" Padding="12,0,8,0" Background="Transparent">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="Assets/install-title-icon@3x.png"
                               Width="24"
                               Height="24"
                               Margin="0,0,8,0" />
                        <TextBlock Text="联想 TokenHub"
                                   FontSize="12"
                                   Foreground="#E5000000"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Style="{StaticResource CaptionButtonStyle}" Click="MinimizeButton_Click">
                            <TextBlock Text="&#xE921;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="10"
                                       Foreground="#E5000000" />
                        </Button>
                        <Button Style="{StaticResource CaptionButtonStyle}" Click="CloseButton_Click">
                            <TextBlock Text="&#xE8BB;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="10"
                                       Foreground="#E5000000" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid x:Name="IntroPanel"
                      Height="352"
                      VerticalAlignment="Top">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="1" Margin="24,0,24,24">
                        <Button x:Name="InstallButton"
                                Content="立即安装"
                                Style="{StaticResource PrimaryInstallButtonStyle}"
                                HorizontalAlignment="Center"
                                Click="InstallButton_Click" />

                        <Grid Margin="0,24,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <CheckBox Grid.Column="0"
                                      IsChecked="True"
                                      Width="24"
                                      Height="24"
                                      VerticalAlignment="Top"
                                      Style="{StaticResource Win11CheckBoxStyle}" />

                            <TextBlock Grid.Column="2"
                                       TextWrapping="Wrap"
                                       LineHeight="18"
                                       MaxWidth="330"
                                       FontSize="12"
                                       Foreground="#E5000000"
                                       VerticalAlignment="Top">
                                <Run Text="阅读并同意 联想 TokenHub " />
                                <Run Text="隐私政策、服务协议、儿童个人信息保护规则"
                                     Foreground="#003E92" />
                            </TextBlock>

                            <Button Grid.Column="4"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Padding="6,0,0,0"
                                    VerticalAlignment="Top"
                                    Click="CustomInstallButton_Click">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock x:Name="CustomToggleText"
                                               Text="自定义安装"
                                               FontSize="12"
                                               Foreground="#99000000"
                                               VerticalAlignment="Center" />
                                    <TextBlock x:Name="CustomChevron"
                                               Text="&#xE972;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="10"
                                               Foreground="#99000000"
                                               Margin="4,1,0,0"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Grid>

                    </StackPanel>
                </Grid>

                <StackPanel x:Name="CustomPanel"
                            Visibility="Collapsed"
                            Margin="24,352,24,0"
                            VerticalAlignment="Top">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="安装位置"
                                   FontSize="12"
                                   Foreground="#99000000"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <Border Grid.Column="1"
                                Height="32"
                                Background="#B3FFFFFF"
                                BorderBrush="#10000000"
                                BorderThickness="1"
                                CornerRadius="4">
                            <TextBlock Text="C:\Program Files\Lenovo"
                                       FontSize="14"
                                       Foreground="#99000000"
                                       VerticalAlignment="Center"
                                       Margin="12,0" />
                        </Border>
                        <Button Grid.Column="2"
                                Content="浏览"
                                Style="{StaticResource SecondaryInstallButtonStyle}"
                                Width="72"
                                Margin="8,0,0,0" />
                    </Grid>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,8,0,0">
                        <TextBlock Text="所需磁盘空间：616MB"
                                   FontSize="14"
                                   Foreground="#E5000000"
                                   Margin="0,0,16,0" />
                        <TextBlock Text="剩余空间：12.74GB"
                                   FontSize="14"
                                   Foreground="#99000000" />
                    </StackPanel>
                </StackPanel>

                <StackPanel x:Name="StatusPanel"
                            Visibility="Visible"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Center"
                            Margin="24,72,24,0">
                    <Image Source="Assets/install-hero-icon@3x.png"
                           Width="48"
                           Height="48"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20" />
                    <TextBlock x:Name="StatusTitle"
                               Text="联想 TokenHub"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#E5000000"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8" />
                    <TextBlock x:Name="StatusDescription"
                               Text="一键切换，多身份随心掌控"
                               FontSize="14"
                               Foreground="#99000000"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               MaxWidth="390" />
                </StackPanel>

                <StackPanel x:Name="ProgressPanel"
                            Visibility="Collapsed"
                            Margin="24,0,24,24"
                            VerticalAlignment="Bottom">
                    <TextBlock x:Name="ProgressText"
                               Text="正在安装组件 0%"
                               FontSize="14"
                               Foreground="#99000000"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Margin="0,0,0,4" />
                    <Grid Height="32" ClipToBounds="True" SizeChanged="ProgressGrid_SizeChanged">
                        <Border Height="3"
                                CornerRadius="2"
                                Background="#0A000000"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Stretch" />
                        <Border x:Name="ProgressTrack"
                                Height="3"
                                CornerRadius="2"
                                Background="#005FB8"
                                Width="0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>

                <Button x:Name="CompleteButton"
                        Content="完成"
                        Style="{StaticResource PrimaryInstallButtonStyle}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,80"
                        Visibility="Collapsed"
                        Click="CloseButton_Click" />
            </Grid>
        </Grid>
    </Border>
</Window>
