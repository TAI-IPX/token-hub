<Window x:Class="TokenHubPanel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TokenHubPanel.ViewModels"
        xmlns:models="clr-namespace:TokenHubPanel.Models"
        Title="联想 Token Hub"
        Icon="Assets/desktop-token-hub-icon@3x.png"
        FontFamily="Microsoft YaHei"
        FontSize="14"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        SizeChanged="Window_SizeChanged"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        Topmost="True"
        MouseDown="Window_MouseDown">
    <Window.DataContext>
        <vm:MainViewModel x:Name="ViewModel" />
    </Window.DataContext>

    <Grid>
        <!-- State Selector (kept hidden for legacy combo-driven demos) -->
        <Border Visibility="Collapsed"
                    Background="#2A161C26"
                    CornerRadius="8"
                    Padding="10"
                    Margin="0,0,0,12"
                    BorderBrush="#61FFFFFF"
                    BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Demo State: "
                               Foreground="White"
                               FontSize="13"
                               VerticalAlignment="Center" />
                    <ComboBox x:Name="StateCombo"
                              Width="220"
                              Height="30"
                              FontSize="12"
                              SelectedIndex="2"
                              SelectionChanged="StateCombo_SelectionChanged"
                              Background="#33FFFFFF"
                              Foreground="White"
                              BorderBrush="#61FFFFFF">
                        <ComboBoxItem Content="首次使用 - 未登录" />
                        <ComboBoxItem Content="首次使用 - 配置中" />
                        <ComboBoxItem Content="正常使用 - 智能匹配关" />
                        <ComboBoxItem Content="正常使用 - 智能匹配开" />
                        <ComboBoxItem Content="待选择模型 - 多应用未配置" />
                        <ComboBoxItem Content="额度不足 - 引导充值" />
                        <ComboBoxItem Content="通知 - 智能匹配开发现新应用" />
                        <ComboBoxItem Content="通知 - 智能匹配关发现新应用" />
                        <ComboBoxItem Content="发现新版本" />
                        <ComboBoxItem Content="未检测到可配置应用" />
                    </ComboBox>
                </StackPanel>
            </Border>

        <!-- The Tray Panel -->
        <!-- Outer: shadow + border only, no ClipToBounds (clipping kills shadow) -->
        <Border x:Name="PanelBorder"
                    Width="440"
                    Height="384"
                    CornerRadius="8"
                    BorderBrush="#0F000000"
                    BorderThickness="1"
                    UseLayoutRounding="True"
                    SnapsToDevicePixels="True"
                    Effect="{StaticResource PanelShadow}">
                <Border.Background>
                    <SolidColorBrush Color="#F0F8FBFF" />
                </Border.Background>

                <!-- Inner: clips all child content to the same 8px radius -->
                <Border x:Name="InnerClipBorder"
                        CornerRadius="7"
                        ClipToBounds="True"
                        SizeChanged="InnerClipBorder_SizeChanged">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- ============ TITLE BAR ============ -->
                    <Border x:Name="TitleBarBorder"
                            Grid.Row="0"
                            Height="48"
                            Background="#70F6F8FC"
                            Padding="16,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Left: Logo + Title + Dropdown -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Image Source="Assets/panel-logo@3x.png"
                                       Width="24" Height="24"
                                       Margin="0,0,8,0" />
                                <TextBlock Text="联想 TokenHub"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="#FF1B1B1F"
                                           VerticalAlignment="Center" />
                                <Button x:Name="AppMenuButton"
                                        Width="16"
                                        Height="16"
                                        Margin="8,0,0,0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Click="AppMenuButton_Click">
                                    <Image Source="Assets/panel-dropdown@3x.png"
                                           Width="16"
                                           Height="16" />
                                </Button>
                                <!-- App menu dropdown -->
                                <Popup x:Name="AppMenuPopup"
                                       PlacementTarget="{Binding ElementName=AppMenuButton}"
                                       Placement="Bottom"
                                       VerticalOffset="6"
                                       HorizontalOffset="-12"
                                       StaysOpen="False"
                                       AllowsTransparency="True"
                                       PopupAnimation="Fade">
                                    <Border Style="{StaticResource FlyoutMenuBorderStyle}" Width="200" Margin="8">
                                        <StackPanel>
                                            <Button Content="数据看板" Style="{StaticResource FlyoutMenuItemStyle}" Tag="dashboard" Click="WebLink_Click" />
                                            <Button Content="使用日志" Style="{StaticResource FlyoutMenuItemStyle}" Tag="logs" Click="WebLink_Click" />
                                            <Button Content="密钥管理" Style="{StaticResource FlyoutMenuItemStyle}" Tag="keys" Click="WebLink_Click" />
                                            <Button Content="模型广场" Style="{StaticResource FlyoutMenuItemStyle}" Tag="marketplace" Click="WebLink_Click" />
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </StackPanel>

                            <!-- Right: NewVersion badge + Settings + Close -->
                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Right">
                                <!-- 新版本 badge (only when logged in and update available) -->
                                <Button Visibility="{Binding NewVersionBadgeVisibility}"
                                        Height="22"
                                        Padding="8,0"
                                        Margin="0,0,12,0"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Click="SettingsButton_Click"
                                        ToolTipService.InitialShowDelay="150"
                                        ToolTipService.Placement="Bottom"
                                        ToolTipService.VerticalOffset="6">
                                    <Button.Background>
                                        <SolidColorBrush Color="#1A005FB8"/>
                                    </Button.Background>
                                    <Button.ToolTip>
                                        <ToolTip Background="Transparent" BorderThickness="0" Padding="0" HasDropShadow="False">
                                            <Border Width="240"
                                                    CornerRadius="8"
                                                    Background="#FAF9FBFF"
                                                    BorderBrush="#14000000"
                                                    BorderThickness="1"
                                                    Padding="14,12"
                                                    Effect="{StaticResource MenuShadow}">
                                                <StackPanel>
                                                    <TextBlock Text="v2.1.0 更新内容"
                                                               FontSize="12" FontWeight="Bold"
                                                               Foreground="#E51B1B1F" Margin="0,0,0,6" />
                                                    <TextBlock Text="• 修复智能匹配偶发失效问题" FontSize="12" Foreground="#B31B1B1F" Margin="0,2,0,0" />
                                                    <TextBlock Text="• 优化应用检测响应速度" FontSize="12" Foreground="#B31B1B1F" Margin="0,2,0,0" />
                                                    <TextBlock Text="• 改进模型切换稳定性" FontSize="12" Foreground="#B31B1B1F" Margin="0,2,0,0" />
                                                    <TextBlock Text="• 新增未检测到应用时的引导提示" FontSize="12" Foreground="#B31B1B1F" Margin="0,2,0,0" />
                                                </StackPanel>
                                            </Border>
                                        </ToolTip>
                                    </Button.ToolTip>
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="4"
                                                    Padding="{TemplateBinding Padding}">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Border Width="13" Height="13" CornerRadius="7"
                                                            Background="#005FB8" Margin="0,0,4,0">
                                                        <TextBlock Text="i" FontSize="9" FontWeight="Bold"
                                                                   Foreground="White" HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="新版本" FontSize="11" FontWeight="SemiBold"
                                                               Foreground="#005FB8" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <!-- Settings gear (hidden when not logged in) -->
                                <Button Width="20"
                                        Height="20"
                                        Margin="0,0,12,0"
                                        Visibility="{Binding SettingsButtonVisibility}"
                                        Style="{StaticResource SecondaryTitleIconButtonStyle}"
                                        Click="SettingsButton_Click"
                                        ToolTip="设置">
                                    <Image Source="Assets/panel-settings@3x.png" Width="16" Height="16"/>
                                </Button>
                                <!-- Close -->
                                <Button Width="20"
                                        Height="20"
                                        Style="{StaticResource SecondaryTitleIconButtonStyle}"
                                        Click="CloseButton_Click"
                                        ToolTip="关闭">
                                    <Image Source="Assets/panel-close@3x.png" Width="20" Height="20"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ============ CONTENT AREA ============ -->
                    <Grid x:Name="ContentHost" Grid.Row="1">

                        <!-- ===== HOME PAGE ===== -->
                        <Grid x:Name="HomePage">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- === ONBOARDING (Login, Configuring) === -->
                            <Grid x:Name="OnboardingContent" Grid.Row="0">

                                <!-- LOGIN STATE -->
                                <Border x:Name="LoginPanel"
                                        Padding="16"
                                        Background="Transparent">
                                    <DockPanel LastChildFill="True">

                                        <!-- CTA button docked to bottom -->
                                        <Button DockPanel.Dock="Bottom"
                                                Content="登录并自动配置"
                                                Margin="0,32,0,0"
                                                Style="{StaticResource OnboardingButtonStyle}"
                                                Click="LoginButton_Click" />

                                        <!-- InfoBlock -->
                                        <StackPanel VerticalAlignment="Top">
                                            <!-- Illustration clipped to 48px -->
                                            <Border Height="48"
                                                    CornerRadius="8"
                                                    ClipToBounds="True"
                                                    HorizontalAlignment="Left"
                                                    Margin="0,0,0,16">
                                                <Image Source="Assets/onboarding-illustration@3x.png"
                                                       Height="80"
                                                       VerticalAlignment="Top"
                                                       HorizontalAlignment="Left"
                                                       Margin="0,-16,0,0" />
                                            </Border>
                                            <!-- Title -->
                                            <TextBlock Text="自动完成服务配置"
                                                       FontSize="24"
                                                       FontWeight="Bold"
                                                       Foreground="#E01B1B1F"
                                                       Margin="0,0,0,16" />
                                            <!-- Description -->
                                            <TextBlock Text="只需简单几步，即可让已安装的 AI 应用使用 Token Hub 提供的模型服务。无需填写复杂信息，也不用手动修改应用设置。"
                                                       FontSize="14"
                                                       LineHeight="22"
                                                       Foreground="#731B1B1F"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,16" />
                                            <!-- Bullets -->
                                            <TextBlock FontSize="14"
                                                       LineHeight="22"
                                                       Foreground="#731B1B1F">
                                                <Run Text="• 自动完成必要设置" /><LineBreak />
                                                <Run Text="• 自动为应用选择合适的模型" /><LineBreak />
                                                <Run Text="• 配置完成后即可使用" />
                                            </TextBlock>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>

                                <!-- CONFIGURING STATE -->
                                <Border x:Name="ConfiguringPanel"
                                        Padding="16"
                                        Background="Transparent">
                                    <DockPanel LastChildFill="True">

                                        <!-- Progress bar docked to bottom -->
                                        <Border DockPanel.Dock="Bottom"
                                                Height="3"
                                                Margin="0,16,0,0"
                                                CornerRadius="99"
                                                Background="#14000000">
                                            <Border x:Name="ProgressBarFill"
                                                    Height="3"
                                                    Width="240"
                                                    HorizontalAlignment="Left"
                                                    CornerRadius="99"
                                                    Background="{StaticResource AccentBrush}" />
                                        </Border>

                                        <!-- InfoBlock vertically centered -->
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="正在完成服务配置"
                                                       FontSize="24"
                                                       FontWeight="Bold"
                                                       Foreground="#E01B1B1F"
                                                       Margin="0,0,0,16" />
                                            <TextBlock Text="正在创建 Token Hub 访问凭证并接入本机服务，请稍候"
                                                       FontSize="14"
                                                       LineHeight="22"
                                                       Foreground="#731B1B1F"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,16" />
                                            <TextBlock FontSize="14"
                                                       LineHeight="22"
                                                       Foreground="#731B1B1F">
                                                <Run Text="• 联想账号认证完成" /><LineBreak />
                                                <Run Text="• 正在创建访问凭证" /><LineBreak />
                                                <Run Text="• 正在启用多模型服务" />
                                            </TextBlock>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>

                                <!-- AUTH-PENDING STATE -->
                                <Border x:Name="AuthPendingPanel"
                                        Padding="16"
                                        Background="Transparent"
                                        Visibility="Collapsed">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="0,40,0,0">
                                            <TextBlock Text="等待登录确认"
                                                       FontSize="24" FontWeight="Bold" Foreground="#E01B1B1F" />
                                            <TextBlock FontSize="14" Foreground="#731B1B1F" Margin="0,16,0,24" TextWrapping="Wrap">
                                                <Run Text="请在联想账号登录窗口中完成认证" />
                                                <LineBreak />
                                                <Run Text="登录成功后，将自动继续配置" />
                                            </TextBlock>
                                        </StackPanel>
                                        <Border Grid.Row="1" Height="3" CornerRadius="99" Background="#14000000" Margin="0,0,0,16">
                                            <Border x:Name="AuthProgressFill" Height="3" Width="240"
                                                    HorizontalAlignment="Left" CornerRadius="99"
                                                    Background="{StaticResource AccentBrush}" />
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- FIRST-RUN STATE (开始配置) -->
                                <Border x:Name="FirstRunPanel"
                                        Padding="16"
                                        Background="Transparent"
                                        Visibility="Collapsed">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" Margin="0,8,0,0">
                                            <TextBlock Text="自动完成服务配置"
                                                       FontSize="24" FontWeight="Bold" Foreground="#E01B1B1F" Margin="0,0,0,12" />
                                            <TextBlock Text="只需简单几步，即可让已安装的 AI 应用使用 Token Hub 提供的模型服务。无需填写复杂信息，也不用手动修改应用设置。"
                                                       FontSize="14" Foreground="#731B1B1F" TextWrapping="Wrap" Margin="0,0,0,12" />
                                            <TextBlock Text="✓ 自动完成必要设置" FontSize="14" Foreground="#731B1B1F" Margin="0,2,0,0" />
                                            <TextBlock Text="✓ 自动为应用选择合适的模型" FontSize="14" Foreground="#731B1B1F" Margin="0,2,0,0" />
                                            <TextBlock Text="✓ 配置完成后即可使用" FontSize="14" Foreground="#731B1B1F" Margin="0,2,0,0" />
                                        </StackPanel>
                                        <Button Grid.Row="1" Content="开始配置"
                                                Style="{StaticResource OnboardingButtonStyle}"
                                                Click="StartOnboarding_Click" />
                                    </Grid>
                                </Border>

                                <!-- READY-TO-CONFIG STATE (自动配置) -->
                                <Border x:Name="ReadyToConfigPanel"
                                        Padding="16"
                                        Background="Transparent"
                                        Visibility="Collapsed">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" Margin="0,8,0,0">
                                            <TextBlock Text="自动完成服务配置"
                                                       FontSize="24" FontWeight="Bold" Foreground="#E01B1B1F" Margin="0,0,0,12" />
                                            <TextBlock Text="Token Hub 将自动创建访问凭证并完成本机接入。所有应用共用一套多模型服务，无需手动复制或修改密钥。"
                                                       FontSize="14" Foreground="#731B1B1F" TextWrapping="Wrap" Margin="0,0,0,12" />
                                            <TextBlock Text="✓ 一套凭证，全局接入" FontSize="14" Foreground="#731B1B1F" Margin="0,2,0,0" />
                                            <TextBlock Text="✓ 自动匹配推荐模型" FontSize="14" Foreground="#731B1B1F" Margin="0,2,0,0" />
                                            <TextBlock Text="✓ 初始化完成后立即可用" FontSize="14" Foreground="#731B1B1F" Margin="0,2,0,0" />
                                        </StackPanel>
                                        <Button Grid.Row="1" Content="自动配置"
                                                Style="{StaticResource OnboardingButtonStyle}"
                                                Click="ConfigureHub_Click" />
                                    </Grid>
                                </Border>

                                <!-- === READY CONTENT (SmartOff/SmartOn/Unconfigured/LowBalance) === -->
                                <Grid x:Name="ReadyContent">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <!-- Smart Mode Toggle -->
                                    <Border Grid.Row="0"
                                            Height="56"
                                            Padding="16,0"
                                            Background="Transparent"
                                            Visibility="{Binding SmartModeVisibility}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="智能模型匹配"
                                                           FontSize="14"
                                                           FontWeight="Bold"
                                                           Foreground="#E01B1B1F" />
                                                <TextBlock Text="按应用特性自动选择模型"
                                                           FontSize="12"
                                                           Foreground="#FF5E626A"
                                                           Margin="0,2,0,0" />
                                            </StackPanel>

                                            <ToggleButton Grid.Column="1"
                                                          Style="{StaticResource WindowsNativeSwitchStyle}"
                                                          IsChecked="{Binding IsSmartMode, Mode=OneWay}"
                                                          VerticalAlignment="Center"
                                                          ToolTip="智能模型匹配"
                                                          PreviewMouseLeftButtonDown="SmartToggle_PreviewMouseLeftButtonDown"
                                                          PreviewKeyDown="SmartToggle_PreviewKeyDown" />
                                        </Grid>
                                    </Border>

                                    <!-- Smart match secondary confirm overlay -->
                                    <Border Grid.Row="1"
                                            x:Name="SmartConfirmPanel"
                                            Visibility="Collapsed"
                                            VerticalAlignment="Top"
                                            Panel.ZIndex="50"
                                            Margin="60,4,16,0"
                                            CornerRadius="8"
                                            Background="#F7F9FBFF"
                                            BorderBrush="#14000000"
                                            BorderThickness="1"
                                            Padding="14,11"
                                            Effect="{StaticResource MenuShadow}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="开启后，所有应用将改用 Token Hub 推荐模型。"
                                                       FontSize="13"
                                                       Foreground="#CC1B1B1F"
                                                       TextWrapping="Wrap"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,12,0" />
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Content="取消"
                                                        Padding="12,0"
                                                        Margin="0,0,6,0"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Click="CancelSmartConfirm_Click" />
                                                <Button Content="开启"
                                                        MinWidth="64"
                                                        Height="30"
                                                        Padding="14,0"
                                                        FontSize="13"
                                                        Style="{StaticResource PrimaryButtonStyle}"
                                                        Click="ConfirmSmartMatch_Click" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- App List -->
                                    <ScrollViewer Grid.Row="1"
                                                  VerticalScrollBarVisibility="Hidden"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- App List Header -->
                                            <Border Grid.Row="0"
                                                    Height="48"
                                                    Padding="16,0">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="应用列表"
                                                               FontSize="14"
                                                               FontWeight="Bold"
                                                               Foreground="#E01B1B1F"
                                                               VerticalAlignment="Center" />
                                                    <Button Grid.Column="1"
                                                            Width="20"
                                                            Height="20"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            VerticalAlignment="Center"
                                                            Cursor="Hand"
                                                            Click="RefreshApps_Click"
                                                            ToolTip="重新检测应用">
                                                        <Image x:Name="RefreshIcon"
                                                               Source="Assets/icon-action@3x.png"
                                                               Width="16" Height="16"
                                                               RenderTransformOrigin="0.5,0.5">
                                                            <Image.RenderTransform>
                                                                <RotateTransform x:Name="RefreshRotate" />
                                                            </Image.RenderTransform>
                                                        </Image>
                                                    </Button>
                                                </Grid>
                                            </Border>

                                            <!-- Tool Items -->
                                            <ItemsControl Grid.Row="1"
                                                          x:Name="ToolListControl"
                                                          Visibility="{Binding ToolListVisibility}"
                                                          ItemsSource="{Binding Tools}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="models:AppTool">
                                                        <Button Height="48"
                                                                Padding="16,0"
                                                                Background="Transparent"
                                                                BorderThickness="0"
                                                                Cursor="Hand"
                                                                FontFamily="Microsoft YaHei"
                                                                HorizontalContentAlignment="Stretch"
                                                                Command="{Binding DataContext.SelectToolCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding Id}">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>

                                                                <!-- App Icon 28x28 rounded 6px -->
                                                                <Border Grid.Column="0"
                                                                        Width="28"
                                                                        Height="28"
                                                                        CornerRadius="6"
                                                                        Background="#EBEAF3FF"
                                                                        Margin="0,0,12,0">
                                                                    <Image Source="{Binding IconPath}"
                                                                           Width="28"
                                                                           Height="28" />
                                                                </Border>

                                                                <!-- Tool Name + new-discovery badge -->
                                                                <StackPanel Grid.Column="1"
                                                                            Orientation="Horizontal"
                                                                            VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding Name}"
                                                                               FontSize="14"
                                                                               Foreground="#991B1B1F"
                                                                               VerticalAlignment="Center"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               MaxWidth="168" />
                                                                    <Border Height="16"
                                                                            CornerRadius="8"
                                                                            Padding="5,0"
                                                                            Margin="6,0,0,0"
                                                                            Background="{StaticResource NewTagBgBrush}">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsNew}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <TextBlock Text="新发现"
                                                                                   FontSize="10"
                                                                                   FontWeight="Medium"
                                                                                   Foreground="{StaticResource NewTagBrush}"
                                                                                   VerticalAlignment="Center" />
                                                                    </Border>
                                                                </StackPanel>

                                                                <!-- Right side: model name + chevron -->
                                                                <StackPanel Grid.Column="2"
                                                                            Orientation="Horizontal"
                                                                            VerticalAlignment="Center">
                                                                    <TextBlock x:Name="ModelNameText"
                                                                               Text="{Binding ModelName}"
                                                                               FontSize="11"
                                                                               Foreground="#FF5E626A"
                                                                               VerticalAlignment="Center" />
                                                                    <Image Source="Assets/icon-chevron-right@3x.png"
                                                                           Width="20"
                                                                           Height="20"
                                                                           Margin="8,0,0,0" />
                                                                </StackPanel>
                                                            </Grid>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Empty state: no apps detected -->
                                            <StackPanel Grid.Row="1"
                                                        Visibility="{Binding NoAppsEmptyVisibility}"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Center"
                                                        Margin="0,32,0,0">
                                                <TextBlock Text="未检测到可配置的应用"
                                                           FontSize="14"
                                                           FontWeight="Bold"
                                                           Foreground="#991B1B1F"
                                                           HorizontalAlignment="Center" />
                                                <TextBlock Text="安装受支持的 AI 应用后，点击检测应用重新扫描"
                                                           FontSize="12"
                                                           Foreground="#7B8088"
                                                           Margin="0,6,0,0"
                                                           TextWrapping="Wrap"
                                                           TextAlignment="Center"
                                                           MaxWidth="260" />
                                                <Button Content="检测应用"
                                                        Width="96"
                                                        MinWidth="96"
                                                        Height="32"
                                                        Padding="16,0"
                                                        Margin="0,16,0,0"
                                                        FontSize="14"
                                                        HorizontalAlignment="Center"
                                                        Style="{StaticResource PrimaryButtonStyle}"
                                                        Click="RefreshApps_Click" />
                                            </StackPanel>
                                        </Grid>
                                    </ScrollViewer>
                                </Grid>
                            </Grid>

                            <!-- ===== ACCOUNT BAR (Footer) ===== -->
                            <Border x:Name="AccountFooter"
                                    Grid.Row="1"
                                    Height="64"
                                    Padding="16,0"
                                    Background="#E0F6F8FC"
                                    BorderBrush="#14000000"
                                    BorderThickness="0,1,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Avatar -->
                                    <Image Grid.Column="0"
                                           Source="Assets/avatar@3x.png"
                                           Width="28"
                                           Height="28"
                                           Margin="0,0,12,0" />

                                    <!-- Account Info -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding PhoneNumber}"
                                                       FontSize="14"
                                                       FontWeight="Bold"
                                                       Foreground="#FF1B1B1F" />
                                            <Border x:Name="BalanceBadge"
                                                    Height="16"
                                                    CornerRadius="99"
                                                    Padding="5,0"
                                                    Margin="6,0,0,0"
                                                    Visibility="Collapsed"
                                                    Background="#FFF0C2">
                                                <TextBlock x:Name="BalanceBadgeText"
                                                           FontSize="10"
                                                           FontWeight="Medium"
                                                           Foreground="#8A5700"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding BalanceText}"
                                                   FontSize="12"
                                                   Foreground="#991B1B1F"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>

                                    <Grid Grid.Column="2" />

                                    <!-- More Button -->
                                    <Button x:Name="MoreButton"
                                            Grid.Column="3"
                                            Width="20"
                                            Height="20"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            VerticalAlignment="Center"
                                            Margin="0,0,12,0"
                                            Click="MoreButton_Click">
                                        <Image Source="Assets/icon-more@3x.png"
                                               Width="20"
                                               Height="20" />
                                    </Button>
                                    <!-- Account menu dropdown -->
                                    <Popup x:Name="AccountMenuPopup"
                                           PlacementTarget="{Binding ElementName=MoreButton}"
                                           Placement="Top"
                                           VerticalOffset="-4"
                                           StaysOpen="False"
                                           AllowsTransparency="True"
                                           PopupAnimation="Fade">
                                        <Border Style="{StaticResource FlyoutMenuBorderStyle}" Width="140" Margin="8">
                                            <StackPanel>
                                                <Button Content="我的账户" Style="{StaticResource FlyoutMenuItemStyle}" Tag="account" Click="WebLink_Click" />
                                                <Button Content="登出" Style="{StaticResource FlyoutMenuItemDangerStyle}" Click="Logout_Click" />
                                            </StackPanel>
                                        </Border>
                                    </Popup>

                                    <!-- Recharge Button -->
                                    <Button Grid.Column="4"
                                            Content="充值"
                                            Width="52"
                                            Height="32"
                                            FontSize="13"
                                            Style="{StaticResource RechargeButtonStyle}"
                                            VerticalAlignment="Center"
                                            Click="RechargeButton_Click" />
                                </Grid>
                            </Border>

                            <!-- Logged-out Footer — hidden per visual demo (login panel has its own 登录 button) -->
                            <Border x:Name="LoggedOutFooter"
                                    Grid.Row="1"
                                    Visibility="Collapsed"
                                    Height="64"
                                    Padding="16,0"
                                    Background="#E0F6F8FC"
                                    BorderBrush="#14000000"
                                    BorderThickness="0,1,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Width="28"
                                            Height="28"
                                            CornerRadius="14"
                                            Background="#EBEAF3FF"
                                            Margin="0,0,12,0">
                                        <TextBlock Text="1"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   Foreground="#FF315FAA"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="登录联想账户"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   Foreground="#FF1B1B1F" />
                                        <TextBlock Text="同步额度并使用模型服务"
                                                   FontSize="12"
                                                   Foreground="#FF5E626A"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>

                                    <Button Grid.Column="2"
                                            Content="登录"
                                            Height="28"
                                            Padding="9,0"
                                            FontSize="11"
                                            Background="#ADFFFFFF"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            VerticalAlignment="Center"
                                            Click="LoginFromFooter_Click" />
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- ===== MODELS PAGE ===== -->
                        <Grid x:Name="ModelsPage" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- Detail Header -->
                            <Border Grid.Row="0"
                                    Height="48"
                                    Padding="16,0"
                                    Background="#70F6F8FC"
                                    BorderBrush="#14000000"
                                    BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Style="{StaticResource SecondaryTitleIconButtonStyle}"
                                            Margin="0,0,8,0"
                                            Click="BackToHome_Click">
                                        <Path Data="M8.8 4.4 3.7 9.5a.7.7 0 0 0 0 1l5.1 5.1 1-1-3.9-3.9h10.4V9.3H5.9l3.9-3.9z"
                                              Fill="#E61B1B1F"
                                              Stretch="Uniform"
                                              Width="16"
                                              Height="16" />
                                    </Button>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding DetailToolName}"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="#FF1B1B1F"
                                               VerticalAlignment="Center" />

                                    <Button Grid.Column="2"
                                            Style="{StaticResource SecondaryTitleIconButtonStyle}"
                                            Width="20"
                                            Height="20"
                                            Click="CloseButton_Click">
                                        <Image Source="Assets/panel-close@3x.png"
                                               Width="20"
                                               Height="20" />
                                    </Button>
                                </Grid>
                            </Border>

                            <!-- Model List -->
                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Hidden"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Padding="0,8,0,0">
                                <ItemsControl x:Name="ModelListControl"
                                              ItemsSource="{Binding CurrentModels}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="models:ModelInfo">
                                            <Border Height="80"
                                                    Padding="20,8"
                                                    Background="Transparent"
                                                    CornerRadius="4"
                                                    Cursor="Hand"
                                                    MouseLeftButtonDown="ModelItem_Click"
                                                    Loaded="ModelRow_Loaded"
                                                    Tag="{Binding Id}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Radio Button 20x20 -->
                                                    <Border x:Name="RadioOuter"
                                                            Grid.Column="0"
                                                            Width="20"
                                                            Height="20"
                                                            CornerRadius="10"
                                                            BorderThickness="1"
                                                            BorderBrush="#9B000000"
                                                            Background="#05000000"
                                                            VerticalAlignment="Center">
                                                        <Ellipse x:Name="RadioBullet"
                                                                 Width="10"
                                                                 Height="10"
                                                                 Fill="Transparent" />
                                                    </Border>

                                                    <!-- Model Info -->
                                                    <StackPanel Grid.Column="1"
                                                                Margin="20,0,0,0"
                                                                VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="14"
                                                                   FontWeight="Bold"
                                                                   Foreground="#E01B1B1F" />
                                                        <TextBlock Margin="0,4,0,0"
                                                                   FontSize="12"
                                                                   Foreground="#991B1B1F"
                                                                   TextWrapping="NoWrap">
                                                            <Run Text="输入" />
                                                            <Run Text="{Binding InputPrice}" />
                                                            <Run Text="  输出" />
                                                            <Run Text="{Binding OutputPrice}" />
                                                            <Run Text="  缓存读取" />
                                                            <Run Text="{Binding CachePrice}" />
                                                            <Run Text="/1M" />
                                                        </TextBlock>
                                                        <ItemsControl ItemsSource="{Binding Tags}"
                                                                      Margin="0,4,0,0">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Orientation="Horizontal" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock Text="{Binding}"
                                                                               Height="16"
                                                                               FontSize="10"
                                                                               Foreground="#FFF59E0B"
                                                                               VerticalAlignment="Center"
                                                                               Margin="0,0,8,0" />
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                    <Border x:Name="ModelBadge"
                                                            Grid.Column="2"
                                                            Height="22"
                                                            CornerRadius="4"
                                                            Padding="8,0"
                                                            Margin="10,0,0,0"
                                                            Background="{StaticResource AccentTagBgBrush}"
                                                            VerticalAlignment="Center"
                                                            Visibility="Collapsed">
                                                        <TextBlock x:Name="ModelBadgeText"
                                                                   Text="当前模型"
                                                                   FontSize="11"
                                                                   FontWeight="Medium"
                                                                   Foreground="{StaticResource AccentTagBrush}"
                                                                   VerticalAlignment="Center" />
                                                    </Border>
                                                </Grid>
                                                </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>

                        <!-- ===== SETTINGS PAGE ===== -->
                        <Grid x:Name="SettingsPage" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- Settings Header -->
                            <Border Grid.Row="0"
                                    Height="48"
                                    Padding="16,0"
                                    Background="#70F6F8FC"
                                    BorderBrush="#14000000"
                                    BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Style="{StaticResource SecondaryTitleIconButtonStyle}"
                                            Margin="0,0,8,0"
                                            Click="BackToHome_Click">
                                        <Path Data="M8.8 4.4 3.7 9.5a.7.7 0 0 0 0 1l5.1 5.1 1-1-3.9-3.9h10.4V9.3H5.9l3.9-3.9z"
                                              Fill="#E61B1B1F"
                                              Stretch="Uniform"
                                              Width="16"
                                              Height="16" />
                                    </Button>

                                    <TextBlock Grid.Column="1"
                                               Text="设置"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="#FF1B1B1F"
                                               VerticalAlignment="Center" />

                                    <Button Grid.Column="2"
                                            Style="{StaticResource SecondaryTitleIconButtonStyle}"
                                            Width="20"
                                            Height="20"
                                            Click="CloseButton_Click">
                                        <Image Source="Assets/panel-close@3x.png"
                                               Width="20"
                                               Height="20" />
                                    </Button>
                                </Grid>
                            </Border>

                            <!-- Settings List -->
                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel>
                                    <!-- 开机自启 -->
                                    <Border Height="64"
                                            Padding="16,0"
                                            BorderBrush="#A4D9DEE8"
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="开机自启" FontSize="14" FontWeight="Bold" Foreground="#E01B1B1F" />
                                                <TextBlock Text="登录 Windows 后自动运行" FontSize="12" Foreground="#991B1B1F" Margin="0,4,0,0" />
                                            </StackPanel>
                                            <ToggleButton Grid.Column="1"
                                                          Style="{StaticResource WindowsNativeSwitchStyle}"
                                                          IsChecked="True"
                                                          VerticalAlignment="Center"
                                                          ToolTip="开机自启" />
                                        </Grid>
                                    </Border>

                                    <!-- 系统通知 -->
                                    <Border Height="64"
                                            Padding="16,0"
                                            BorderBrush="#A4D9DEE8"
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="系统通知" FontSize="14" FontWeight="Bold" Foreground="#E01B1B1F" />
                                                <TextBlock Text="发现新应用和切换异常时提醒" FontSize="12" Foreground="#991B1B1F" Margin="0,4,0,0" />
                                            </StackPanel>
                                            <ToggleButton Grid.Column="1"
                                                          Style="{StaticResource WindowsNativeSwitchStyle}"
                                                          IsChecked="True"
                                                          VerticalAlignment="Center"
                                                          ToolTip="系统通知" />
                                        </Grid>
                                    </Border>

                                    <!-- 自动检测新应用 -->
                                    <Border Height="64"
                                            Padding="16,0"
                                            BorderBrush="#A4D9DEE8"
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="自动检测新应用" FontSize="14" FontWeight="Bold" Foreground="#E01B1B1F" />
                                                <TextBlock Text="安装应用后自动加入列表" FontSize="12" Foreground="#991B1B1F" Margin="0,4,0,0" />
                                            </StackPanel>
                                            <ToggleButton Grid.Column="1"
                                                          Style="{StaticResource WindowsNativeSwitchStyle}"
                                                          IsChecked="True"
                                                          VerticalAlignment="Center"
                                                          ToolTip="自动检测新应用" />
                                        </Grid>
                                    </Border>

                                    <!-- 接管前二次确认 -->
                                    <Border Height="64"
                                            Padding="16,0"
                                            BorderBrush="#A4D9DEE8"
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="接管前二次确认" FontSize="14" FontWeight="Bold" Foreground="#E01B1B1F" />
                                                <TextBlock Text="开启智能匹配前确认是否由 Token Hub 管理应用配置"
                                                           FontSize="12" Foreground="#991B1B1F" Margin="0,4,0,0"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                            <ToggleButton Grid.Column="1"
                                                          Style="{StaticResource WindowsNativeSwitchStyle}"
                                                          IsChecked="True"
                                                          VerticalAlignment="Center"
                                                          ToolTip="接管前二次确认" />
                                        </Grid>
                                    </Border>

                                    <!-- 版本号 -->
                                    <Border Height="64" Padding="16,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="版本号" FontSize="14" FontWeight="Bold" Foreground="#E01B1B1F" />
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock Text="v2.0.4" FontSize="12" Foreground="#991B1B1F" />
                                                    <TextBlock Text="新版本 2.1.0" FontSize="12" Foreground="#005FB8"
                                                               FontWeight="Medium" Margin="12,0,0,0"
                                                               Visibility="{Binding NewVersionBadgeVisibility}" />
                                                </StackPanel>
                                            </StackPanel>
                                            <!-- 检查更新 (default, white) -->
                                            <Button Grid.Column="1"
                                                    Content="检查更新"
                                                    Height="30" Padding="14,0" FontSize="13"
                                                    Foreground="#CC1B1B1F"
                                                    Cursor="Hand"
                                                    Click="CheckUpdate_Click"
                                                    Visibility="{Binding CheckUpdateButtonVisibility}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="#B3FFFFFF" CornerRadius="4"
                                                                BorderThickness="1" BorderBrush="#1A000000"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <!-- 立即更新 (when new version, accent) -->
                                            <Button Grid.Column="1"
                                                    Content="立即更新"
                                                    Height="30" Padding="14,0" FontSize="13"
                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                    Cursor="Hand"
                                                    Click="DoUpdate_Click"
                                                    Visibility="{Binding NewVersionBadgeVisibility}" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Grid>

                    <!-- ===== NOTIFICATION POPUP ===== -->
                    <Border x:Name="NotificationPanel"
                            Grid.Row="0"
                            Grid.RowSpan="3"
                            Width="364"
                            CornerRadius="8"
                            BorderBrush="#2E000000"
                            BorderThickness="1"
                            Background="#E6F8FBFF"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Margin="0"
                            Visibility="Collapsed"
                            Effect="{StaticResource NotificationShadow}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Notification Header -->
                            <Border Grid.Row="0"
                                    Height="32"
                                    Padding="16,0,0,0"
                                    BorderThickness="0,0,0,1"
                                    Background="#70FFFFFF">
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="#14000000"/>
                                </Border.BorderBrush>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Image Source="Assets/desktop-token-hub-icon@3x.png"
                                               Width="16" Height="16"
                                               Margin="0,0,8,0" />
                                        <TextBlock Text="联想TokenHub"
                                                   FontSize="12"
                                                   Foreground="#E51B1B1F"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>

                                    <Button Grid.Column="2"
                                            Width="46"
                                            Height="32"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            FontSize="14"
                                            Foreground="#CC1B1B1F"
                                            Cursor="Hand"
                                            Content="&#x00D7;"
                                            Click="DismissNotification_Click" />
                                </Grid>
                            </Border>

                            <!-- Auto Discovery Body (smart match ON) -->
                            <StackPanel x:Name="AutoNotificationBody"
                                        Grid.Row="1"
                                        Margin="16,16,16,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Image Grid.Column="0"
                                           Source="Assets/app-qclaw@3x.png"
                                           Width="48" Height="48"
                                           VerticalAlignment="Top"
                                           Margin="0" />

                                    <StackPanel Grid.Column="1"
                                                Margin="16,0,0,0">
                                        <TextBlock Text="QClaw 已完成模型匹配"
                                                   FontSize="16"
                                                   FontWeight="Bold"
                                                   Foreground="#E51B1B1F" />
                                        <TextBlock Text="已根据应用特性自动选择 DeepSeek V4 Flash，现在可以直接使用。"
                                                   FontSize="14"
                                                   Foreground="#991B1B1F"
                                                   Margin="0,4,0,0"
                                                   TextWrapping="Wrap" />
                                        <WrapPanel Margin="0,8,0,0">
                                            <Border Height="18"
                                                    Padding="6,0"
                                                    CornerRadius="4"
                                                    Background="#1A0F6CBD"
                                                    Margin="0,0,4,0">
                                                <TextBlock Text="文本生成"
                                                           FontSize="10"
                                                           Foreground="#FF0F6CBD"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                            <Border Height="18"
                                                    Padding="6,0"
                                                    CornerRadius="4"
                                                    Background="#1A0F6CBD"
                                                    Margin="0,0,4,0">
                                                <TextBlock Text="轻量快速"
                                                           FontSize="10"
                                                           Foreground="#FF0F6CBD"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                            <Border Height="18"
                                                    Padding="6,0"
                                                    CornerRadius="4"
                                                    Background="#1A0F6CBD">
                                                <TextBlock Text="DeepSeek"
                                                           FontSize="10"
                                                           Foreground="#FF0F6CBD"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                        </WrapPanel>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <!-- Manual Discovery Body (smart match OFF) -->
                            <StackPanel x:Name="ManualNotificationBody"
                                        Grid.Row="1"
                                        Margin="16,16,16,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Image Grid.Column="0"
                                           Source="Assets/app-qclaw@3x.png"
                                           Width="48" Height="48"
                                           VerticalAlignment="Top"
                                           Margin="0" />

                                    <StackPanel Grid.Column="1"
                                                Margin="16,0,0,0">
                                        <TextBlock Text="发现新应用 QClaw"
                                                   FontSize="16"
                                                   FontWeight="Bold"
                                                   Foreground="#E51B1B1F" />
                                        <TextBlock Text="为 QClaw 选择模型即可马上使用"
                                                   FontSize="14"
                                                   Foreground="#991B1B1F"
                                                   Margin="0,4,0,0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <!-- Notification Actions (Manual only) -->
                            <Border x:Name="NotificationActions"
                                    Grid.Row="2"
                                    Padding="16">
                                <Grid>
                                    <Button Content="查看配置"
                                            HorizontalAlignment="Right"
                                            MinWidth="84"
                                            Height="30"
                                            Padding="16,0"
                                            FontSize="13"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Cursor="Hand"
                                            Click="GoToToolFromNotification_Click" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- ===== TOAST ===== -->
                    <Border x:Name="ToastBorder"
                            Grid.Row="0"
                            Grid.RowSpan="3"
                            CornerRadius="4"
                            Background="#F01F232A"
                            Padding="13,8"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Margin="0,54,0,0"
                            Visibility="Collapsed"
                            Effect="{StaticResource MenuShadow}">
                        <TextBlock x:Name="ToastText"
                                   Text=""
                                   FontSize="12"
                                   Foreground="White" />
                    </Border>
                </Grid>
                </Border><!-- /inner clip border -->
        </Border>
    </Grid>
</Window>
