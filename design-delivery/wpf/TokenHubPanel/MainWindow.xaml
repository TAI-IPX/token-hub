<Window x:Class="TokenHubPanel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TokenHubPanel.ViewModels"
        xmlns:models="clr-namespace:TokenHubPanel.Models"
        Title="联想 Token Hub"
        Icon="Assets/desktop-token-hub-icon@3x.png"
        FontFamily="Microsoft YaHei"
        FontSize="14"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        ShowInTaskbar="False"
        SizeChanged="Window_SizeChanged"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        Topmost="True"
        MouseDown="Window_MouseDown">
    <Window.DataContext>
        <vm:MainViewModel x:Name="ViewModel" />
    </Window.DataContext>

    <Grid>
        <!-- State Selector (kept hidden for legacy combo-driven demos) -->
        <Border Visibility="Collapsed"
                    Background="#2A161C26"
                    CornerRadius="8"
                    Padding="10"
                    Margin="0,0,0,12"
                    BorderBrush="#61FFFFFF"
                    BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Demo State: "
                               Foreground="White"
                               FontSize="13"
                               VerticalAlignment="Center" />
                    <ComboBox x:Name="StateCombo"
                              Width="220"
                              Height="30"
                              FontSize="12"
                              SelectedIndex="2"
                              SelectionChanged="StateCombo_SelectionChanged"
                              Background="#33FFFFFF"
                              Foreground="White"
                              BorderBrush="#61FFFFFF">
                        <ComboBoxItem Content="首次使用 - 未登录" />
                        <ComboBoxItem Content="首次使用 - 登陆失败" />
                        <ComboBoxItem Content="首次使用 - 配置中" />
                        <ComboBoxItem Content="正常使用 - 智能匹配关" />
                        <ComboBoxItem Content="正常使用 - 智能匹配开" />
                        <ComboBoxItem Content="待选择模型 - 多应用未配置" />
                        <ComboBoxItem Content="额度不足 - 引导充值" />
                        <ComboBoxItem Content="通知 - 智能匹配开发现新应用" />
                        <ComboBoxItem Content="通知 - 智能匹配关发现新应用" />
                        <ComboBoxItem Content="发现新版本" />
                        <ComboBoxItem Content="未检测到可配置应用" />
                    </ComboBox>
                </StackPanel>
            </Border>

        <!-- The Tray Panel -->
        <!-- Outer: image background + separate border for crisp rendering -->
        <Border x:Name="PanelBorder"
                    Width="360"
                    Height="400"
                    Margin="12,12,12,20"
                    CornerRadius="8"
                    BorderBrush="#0F000000"
                    BorderThickness="1"
                    UseLayoutRounding="True"
                    SnapsToDevicePixels="True"
                    Effect="{StaticResource NotificationShadow}">
                <Border.Background>
                    <ImageBrush ImageSource="Assets/panel-bg.png" Stretch="Fill" />
                </Border.Background>

                <!-- Inner: clips all child content to the same 8px radius -->
                <Border x:Name="InnerClipBorder"
                        CornerRadius="7"
                        SizeChanged="InnerClipBorder_SizeChanged">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- ============ TITLE BAR ============ -->
                    <Border x:Name="TitleBarBorder"
                            Grid.Row="0"
                            Height="48"
                            Background="Transparent"
                            Padding="4,0,16,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Left: Logo + Title + Dropdown -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Image Source="Assets/panel-logo@3x.png"
                                       Width="40" Height="40"
                                       Margin="0,0,4,0" />
                                <TextBlock Text="联想 TokenHub"
                                           FontSize="14"
                                           FontWeight="Regular"
                                           Foreground="#FF1B1B1F"
                                           VerticalAlignment="Center" />
                                <Button x:Name="AppMenuButton"
                                        Width="18"
                                        Height="18"
                                        Margin="4,0,0,0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Click="AppMenuButton_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" CornerRadius="4" Background="Transparent">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#0A000000" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Image Source="Assets/panel-dropdown@3x.png"
                                           Width="18"
                                           Height="18" />
                                </Button>
                                <!-- App menu dropdown -->
                                <Popup x:Name="AppMenuPopup"
                                       PlacementTarget="{Binding ElementName=AppMenuButton}"
                                       Placement="Bottom"
                                       VerticalOffset="6"
                                       HorizontalOffset="-12"
                                       StaysOpen="False"
                                       AllowsTransparency="True"
                                       PopupAnimation="Fade"
                                       Opened="AppMenuPopup_Opened">
                                    <Border Style="{StaticResource FlyoutMenuBorderStyle}" Width="140" Margin="8">
                                        <StackPanel>
                                            <Button Content="数据看板" Style="{StaticResource FlyoutMenuItemStyle}" Tag="dashboard" Click="WebLink_Click" />
                                            <Button Content="使用日志" Style="{StaticResource FlyoutMenuItemStyle}" Tag="logs" Click="WebLink_Click" />
                                            <Button Content="密钥管理" Style="{StaticResource FlyoutMenuItemStyle}" Tag="keys" Click="WebLink_Click" />
                                            <Button Content="模型广场" Style="{StaticResource FlyoutMenuItemStyle}" Tag="marketplace" Click="WebLink_Click" />
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </StackPanel>

                            <!-- Right: NewVersion badge + Settings + Close -->
                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Right">
                                <!-- 新版本 badge (only when logged in and update available) -->
                                <Button Visibility="{Binding NewVersionBadgeVisibility}"
                                        Height="28"
                                        Padding="6,4,10,4"
                                        Margin="0,0,12,0"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Click="NewVersionBadge_Click">
                                    <Button.Background>
                                        <SolidColorBrush Color="#B8FFFFFF"/>
                                    </Button.Background>
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="#1A000000"
                                                    BorderThickness="1"
                                                    CornerRadius="14"
                                                    Padding="{TemplateBinding Padding}">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Image Source="Assets/icon-update@3x.png"
                                                           Width="16" Height="16"
                                                           Margin="0,0,2,0" />
                                                    <TextBlock Text="新版本"
                                                               FontSize="12"
                                                               FontWeight="Regular"
                                                               Foreground="#FF000000"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#1A000000" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <!-- Settings gear (hidden when not logged in) -->
                                <Button Width="20"
                                        Height="20"
                                        Margin="0,0,12,0"
                                        Visibility="{Binding SettingsButtonVisibility}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Click="SettingsButton_Click"
                                        ToolTip="设置">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" CornerRadius="4" Background="Transparent">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#0A000000" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Image Source="Assets/panel-settings@3x.png" Width="20" Height="20"/>
                                </Button>
                                <!-- Close -->
                                <Button Width="20"
                                        Height="20"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Click="CloseButton_Click"
                                        ToolTip="关闭">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" CornerRadius="4" Background="Transparent">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#0A000000" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Image Source="Assets/panel-close@3x.png" Width="20" Height="20"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ============ CONTENT AREA ============ -->
                    <Grid x:Name="ContentHost" Grid.Row="1">

                        <!-- ===== HOME PAGE ===== -->
                        <Grid x:Name="HomePage">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- === ONBOARDING (Login, Configuring) === -->
                            <Grid x:Name="OnboardingContent" Grid.Row="0">

                                <!-- LOGIN STATE — Figma 407:459 -->
                                <Border x:Name="LoginPanel"
                                        Padding="16"
                                        Background="Transparent">
                                    <DockPanel LastChildFill="True">

                                        <!-- CTA button docked to bottom -->
                                        <Button DockPanel.Dock="Bottom"
                                                Content="登录并自动配置"
                                                Margin="0,32,0,0"
                                                Style="{StaticResource OnboardingButtonStyle}"
                                                Click="LoginButton_Click" />

                                        <!-- InfoBlock -->
                                        <StackPanel VerticalAlignment="Top" Margin="8,0,0,0">
                                            <!-- Logo 56×56 white circle -->
                                            <Border Width="56" Height="56"
                                                    CornerRadius="28"
                                                    Background="White"
                                                    HorizontalAlignment="Left"
                                                    Margin="0,0,0,20">
                                                <Image Source="Assets/login-hero.png"
                                                       Width="56" Height="56" />
                                            </Border>
                                            <!-- Title: 20px Regular (Figma 407:459) -->
                                            <TextBlock Text="只需一步，自动完成服务配置"
                                                       FontSize="20"
                                                       Foreground="#E0000000"
                                                       Margin="0,0,0,6" />
                                            <!-- Subtitle: 12px, line 19px, #333 (Figma 407:459) -->
                                            <TextBlock Text="让 AI 应用无缝接入 Token Hub 模型服务"
                                                       FontSize="12"
                                                       LineHeight="19"
                                                       Foreground="#FF333333"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,18" />
                                            <!-- Checkmark items: 18×18 icon + 8px gap + text, 8px between items -->
                                            <StackPanel>
                                                <!-- Item 1 -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <Image Source="Assets/icon-check@3x.png"
                                                           Width="18" Height="18"
                                                           Margin="0,0,8,0" />
                                                    <TextBlock Text="自动完成必要设置"
                                                               FontSize="12"
                                                               Foreground="#73000000"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                                <!-- Item 2 -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <Image Source="Assets/icon-check@3x.png"
                                                           Width="18" Height="18"
                                                           Margin="0,0,8,0" />
                                                    <TextBlock Text="自动为应用选择合适的模型"
                                                               FontSize="12"
                                                               Foreground="#73000000"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                                <!-- Item 3 -->
                                                <StackPanel Orientation="Horizontal">
                                                    <Image Source="Assets/icon-check@3x.png"
                                                           Width="18" Height="18"
                                                           Margin="0,0,8,0" />
                                                    <TextBlock Text="配置完成后即可使用"
                                                               FontSize="12"
                                                               Foreground="#73000000"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>

                                <!-- LOGIN FAILED STATE — Figma 810:677 -->
                                <Border x:Name="LoginFailedPanel"
                                        Padding="16"
                                        Background="Transparent"
                                        Visibility="Collapsed">
                                    <DockPanel LastChildFill="True">
                                        <Button DockPanel.Dock="Bottom"
                                                Content="重新登陆"
                                                Margin="0,32,0,0"
                                                Style="{StaticResource OnboardingButtonStyle}"
                                                Click="LoginButton_Click" />
                                        <StackPanel VerticalAlignment="Top" Margin="8,0,0,0">
                                            <Border Width="56" Height="56" CornerRadius="28" Background="White"
                                                    HorizontalAlignment="Left" Margin="0,0,0,20">
                                                <Image Source="Assets/login-hero.png" Width="56" Height="56" />
                                            </Border>
                                            <TextBlock Text="账号登陆失败，请重试"
                                                       FontSize="20"
                                                       Foreground="#E0000000"
                                                       Margin="0,0,0,6" />
                                            <TextBlock Text="只需一步，自动完成服务配置"
                                                       FontSize="12"
                                                       LineHeight="19"
                                                       Foreground="#FF333333"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,18" />
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <Image Source="Assets/icon-check@3x.png" Width="18" Height="18" Margin="0,0,8,0" />
                                                    <TextBlock Text="自动完成必要设置" FontSize="12" Foreground="#73000000" VerticalAlignment="Center" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <Image Source="Assets/icon-check@3x.png" Width="18" Height="18" Margin="0,0,8,0" />
                                                    <TextBlock Text="自动为应用选择合适的模型" FontSize="12" Foreground="#73000000" VerticalAlignment="Center" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Image Source="Assets/icon-check@3x.png" Width="18" Height="18" Margin="0,0,8,0" />
                                                    <TextBlock Text="配置完成后即可使用" FontSize="12" Foreground="#73000000" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>

                                <!-- CONFIGURING STATE -->
                                <Border x:Name="ConfiguringPanel"
                                        Padding="16"
                                        Background="Transparent">
                                    <DockPanel LastChildFill="True">

                                        <!-- Progress bar docked to bottom -->
                                        <Grid DockPanel.Dock="Bottom" Height="4" Margin="0,16,0,0" ClipToBounds="True">
                                            <Border Background="#0A000000" CornerRadius="2" />
                                            <Border x:Name="ConfiguringTrack"
                                                    Width="100"
                                                    HorizontalAlignment="Left"
                                                    Background="{StaticResource AccentBrush}"
                                                    CornerRadius="2"
                                                    RenderTransformOrigin="0.5,0.5">
                                                <Border.RenderTransform>
                                                    <TranslateTransform x:Name="ConfiguringSlide" />
                                                </Border.RenderTransform>
                                            </Border>
                                        </Grid>

                                        <!-- InfoBlock -->
                                        <StackPanel VerticalAlignment="Top" Margin="8,0,0,0">
                                            <!-- Logo 56×56 white circle -->
                                            <Border Width="56" Height="56"
                                                    CornerRadius="28"
                                                    Background="White"
                                                    HorizontalAlignment="Left"
                                                    Margin="0,0,0,20">
                                                <Image Source="Assets/login-hero.png"
                                                       Width="56" Height="56" />
                                            </Border>
                                            <TextBlock Text="正在完成服务配置"
                                                       FontSize="20"
                                                       Foreground="#E0000000"
                                                       Margin="0,0,0,6" />
                                            <TextBlock Text="正在创建 Token Hub 访问凭证并接入本机服务"
                                                       FontSize="12"
                                                       LineHeight="19"
                                                       Foreground="#FF333333"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,16" />
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <Image Source="Assets/icon-check@3x.png"
                                                           Width="18" Height="18"
                                                           Margin="0,0,8,0" />
                                                    <TextBlock Text="联想账号认证完成"
                                                               FontSize="12"
                                                               Foreground="#73000000"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <Image Source="Assets/icon-check@3x.png"
                                                           Width="18" Height="18"
                                                           Margin="0,0,8,0" />
                                                    <TextBlock Text="正在创建访问凭证"
                                                               FontSize="12"
                                                               Foreground="#73000000"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Image Source="Assets/icon-check@3x.png"
                                                           Width="18" Height="18"
                                                           Margin="0,0,8,0" />
                                                    <TextBlock Text="正在启用多模型服务"
                                                               FontSize="12"
                                                               Foreground="#73000000"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>

                                <!-- AUTH-PENDING STATE -->
                                <Border x:Name="AuthPendingPanel"
                                        Padding="16"
                                        Background="Transparent"
                                        Visibility="Collapsed">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" VerticalAlignment="Top" Margin="8,0,0,0">
                                            <!-- Logo 56×56 white circle -->
                                            <Border Width="56" Height="56"
                                                    CornerRadius="28"
                                                    Background="White"
                                                    HorizontalAlignment="Left"
                                                    Margin="0,0,0,20">
                                                <Image Source="Assets/login-hero.png"
                                                       Width="56" Height="56" />
                                            </Border>
                                            <!-- Title -->
                                            <TextBlock Text="等待登陆确认"
                                                       FontSize="20" Foreground="#E0000000"
                                                       Margin="0,0,0,6" />
                                            <!-- Description -->
                                            <TextBlock Text="已打开账号登陆窗口，登陆成功后将自动完成服务配置"
                                                       FontSize="12" Foreground="#FF333333" Margin="0,0,0,16"
                                                       LineHeight="19" TextWrapping="Wrap" />
                                            <!-- Checkmark items -->
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <Image Source="Assets/icon-check@3x.png" Width="18" Height="18" Margin="0,0,8,0" />
                                                    <TextBlock Text="自动完成必要设置" FontSize="12" Foreground="#73000000" VerticalAlignment="Center" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <Image Source="Assets/icon-check@3x.png" Width="18" Height="18" Margin="0,0,8,0" />
                                                    <TextBlock Text="自动为应用选择合适的模型" FontSize="12" Foreground="#73000000" VerticalAlignment="Center" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Image Source="Assets/icon-check@3x.png" Width="18" Height="18" Margin="0,0,8,0" />
                                                    <TextBlock Text="配置完成后即可使用" FontSize="12" Foreground="#73000000" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                        <Grid Grid.Row="1" Height="4" Margin="0,0,0,16" ClipToBounds="True">
                                            <Border Background="#0A000000" CornerRadius="2" />
                                            <Border x:Name="AuthPendingTrack"
                                                    Width="100"
                                                    HorizontalAlignment="Left"
                                                    Background="{StaticResource AccentBrush}"
                                                    CornerRadius="2"
                                                    RenderTransformOrigin="0.5,0.5">
                                                <Border.RenderTransform>
                                                    <TranslateTransform x:Name="AuthPendingSlide" />
                                                </Border.RenderTransform>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <!-- FIRST-RUN STATE (开始配置) -->
                                <Border x:Name="FirstRunPanel"
                                        Padding="16"
                                        Background="Transparent"
                                        Visibility="Collapsed">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" VerticalAlignment="Top" Margin="8,0,0,0">
                                            <Border Width="56" Height="56" CornerRadius="28" Background="White"
                                                    HorizontalAlignment="Left" Margin="0,0,0,20">
                                                <Image Source="Assets/login-hero.png" Width="56" Height="56" />
                                            </Border>
                                            <TextBlock Text="自动完成服务配置"
                                                       FontSize="20" Foreground="#E0000000" Margin="0,0,0,6" />
                                            <TextBlock Text="只需简单几步，即可让已安装的 AI 应用使用 Token Hub 提供的模型服务。"
                                                       FontSize="12" LineHeight="19" Foreground="#FF333333" TextWrapping="Wrap" Margin="0,0,0,16" />
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <Image Source="Assets/icon-check@3x.png" Width="18" Height="18" Margin="0,0,8,0" />
                                                    <TextBlock Text="自动完成必要设置" FontSize="12" Foreground="#73000000" VerticalAlignment="Center" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <Image Source="Assets/icon-check@3x.png" Width="18" Height="18" Margin="0,0,8,0" />
                                                    <TextBlock Text="自动为应用选择合适的模型" FontSize="12" Foreground="#73000000" VerticalAlignment="Center" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Image Source="Assets/icon-check@3x.png" Width="18" Height="18" Margin="0,0,8,0" />
                                                    <TextBlock Text="配置完成后即可使用" FontSize="12" Foreground="#73000000" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                        <Button Grid.Row="1" Content="开始配置"
                                                Style="{StaticResource OnboardingButtonStyle}"
                                                Click="StartOnboarding_Click" />
                                    </Grid>
                                </Border>

                                <!-- READY-TO-CONFIG STATE (自动配置) -->
                                <Border x:Name="ReadyToConfigPanel"
                                        Padding="16"
                                        Background="Transparent"
                                        Visibility="Collapsed">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" VerticalAlignment="Top" Margin="8,0,0,0">
                                            <Border Width="56" Height="56" CornerRadius="28" Background="White"
                                                    HorizontalAlignment="Left" Margin="0,0,0,20">
                                                <Image Source="Assets/login-hero.png" Width="56" Height="56" />
                                            </Border>
                                            <TextBlock Text="自动完成服务配置"
                                                       FontSize="20" Foreground="#E0000000" Margin="0,0,0,6" />
                                            <TextBlock Text="Token Hub 将自动创建访问凭证并完成本机接入。"
                                                       FontSize="12" LineHeight="19" Foreground="#FF333333" TextWrapping="Wrap" Margin="0,0,0,16" />
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <Image Source="Assets/icon-check@3x.png" Width="18" Height="18" Margin="0,0,8,0" />
                                                    <TextBlock Text="一套凭证，全局接入" FontSize="12" Foreground="#73000000" VerticalAlignment="Center" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <Image Source="Assets/icon-check@3x.png" Width="18" Height="18" Margin="0,0,8,0" />
                                                    <TextBlock Text="自动匹配推荐模型" FontSize="12" Foreground="#73000000" VerticalAlignment="Center" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Image Source="Assets/icon-check@3x.png" Width="18" Height="18" Margin="0,0,8,0" />
                                                    <TextBlock Text="初始化完成后立即可用" FontSize="12" Foreground="#73000000" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                        <Button Grid.Row="1" Content="自动配置"
                                                Style="{StaticResource OnboardingButtonStyle}"
                                                Click="ConfigureHub_Click" />
                                    </Grid>
                                </Border>

                                <!-- === READY CONTENT (SmartOff/SmartOn/Unconfigured/LowBalance) === -->
                                <Grid x:Name="ReadyContent">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <!-- Smart Mode Toggle -->
                                    <Border Grid.Row="0"
                                            Height="56"
                                            Padding="16,0"
                                            Background="Transparent"
                                            Visibility="{Binding SmartModeVisibility}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="智能模型匹配"
                                                           FontSize="14"
                                                           FontWeight="Bold"
                                                           Foreground="#FF1B1B1F" />
                                                <TextBlock Text="按应用特性自动选择模型"
                                                           FontSize="12"
                                                           Foreground="#99000000"
                                                           Margin="0,2,0,0" />
                                            </StackPanel>

                                            <ToggleButton Grid.Column="1"
                                                          Style="{StaticResource WindowsNativeSwitchStyle}"
                                                          IsChecked="{Binding IsSmartMode, Mode=OneWay}"
                                                          VerticalAlignment="Center"
                                                          ToolTip="智能模型匹配"
                                                          PreviewMouseLeftButtonDown="SmartToggle_PreviewMouseLeftButtonDown"
                                                          PreviewKeyDown="SmartToggle_PreviewKeyDown" />
                                        </Grid>
                                    </Border>

                                    <!-- Smart match secondary confirm overlay -->
                                    <Border Grid.Row="1"
                                            x:Name="SmartConfirmPanel"
                                            Visibility="Collapsed"
                                            VerticalAlignment="Top"
                                            Panel.ZIndex="50"
                                            Margin="16,4,16,0"
                                            CornerRadius="8"
                                            Background="White"
                                            BorderBrush="#0F000000"
                                            BorderThickness="1"
                                            Padding="16"
                                            Effect="{StaticResource ConfirmDialogShadow}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="开启后，所有应用将改用 Token Hub 推荐模型。"
                                                       FontSize="13"
                                                       Foreground="#CC1B1B1F"
                                                       TextWrapping="Wrap"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,12,0" />
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Content="取消"
                                                        Width="52"
                                                        Height="30"
                                                        Padding="0"
                                                        Margin="0,0,6,0"
                                                        FontSize="13"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Click="CancelSmartConfirm_Click" />
                                                <Button Content="开启"
                                                        Width="52"
                                                        Height="30"
                                                        Padding="0"
                                                        FontSize="13"
                                                        Style="{StaticResource PrimaryButtonStyle}"
                                                        Click="ConfirmSmartMatch_Click" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- App List Area (hidden when no apps) -->
                                    <ScrollViewer Grid.Row="1"
                                                  VerticalScrollBarVisibility="Hidden"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  Visibility="{Binding ToolListVisibility}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- App List Header -->
                                            <Border Grid.Row="0"
                                                    Height="48"
                                                    Padding="16,0">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="应用列表"
                                                               FontSize="14"
                                                               FontWeight="Bold"
                                                               Foreground="#E0000000"
                                                               VerticalAlignment="Center" />
                                                    <Button Grid.Column="1"
                                                            Width="20"
                                                            Height="20"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            VerticalAlignment="Center"
                                                            Cursor="Hand"
                                                            Click="RefreshApps_Click"
                                                            ToolTip="重新检测应用">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="bd" CornerRadius="4" Background="Transparent">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="bd" Property="Background" Value="#0A000000" />
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                        <Image x:Name="RefreshIcon"
                                                               Source="Assets/icon-action@3x.png"
                                                               Width="16" Height="16"
                                                               RenderTransformOrigin="0.5,0.5">
                                                            <Image.RenderTransform>
                                                                <RotateTransform x:Name="RefreshRotate" />
                                                            </Image.RenderTransform>
                                                        </Image>
                                                    </Button>
                                                </Grid>
                                            </Border>

                                            <!-- Tool Items -->
                                            <ItemsControl Grid.Row="1"
                                                          x:Name="ToolListControl"
                                                          ItemsSource="{Binding Tools}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="models:AppTool">
                                                        <Button Style="{StaticResource ToolListItemStyle}"
                                                                Command="{Binding DataContext.SelectToolCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding Id}">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>

                                                                <!-- App Icon 28x28 rounded 6px -->
                                                                <Border Grid.Column="0"
                                                                        Width="28"
                                                                        Height="28"
                                                                        CornerRadius="6"
                                                                        Background="#EBEAF3FF"
                                                                        Margin="0,0,12,0">
                                                                    <Image Source="{Binding IconPath}"
                                                                           Width="28"
                                                                           Height="28" />
                                                                </Border>

                                                                <!-- Tool Name + new-discovery badge -->
                                                                <StackPanel Grid.Column="1"
                                                                            Orientation="Horizontal"
                                                                            VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding Name}"
                                                                               FontSize="14"
                                                                               Foreground="#E0000000"
                                                                               VerticalAlignment="Center"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               MaxWidth="168" />
                                                                    <Border Height="16"
                                                                            CornerRadius="8"
                                                                            Padding="5,0"
                                                                            Margin="6,0,0,0"
                                                                            Background="{StaticResource NewTagBgBrush}">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsNew}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <TextBlock Text="新发现"
                                                                                   FontSize="10"
                                                                                   FontWeight="Medium"
                                                                                   Foreground="{StaticResource NewTagBrush}"
                                                                                   VerticalAlignment="Center" />
                                                                    </Border>
                                                                </StackPanel>

                                                                <!-- Right side: model name + chevron -->
                                                                <StackPanel Grid.Column="2"
                                                                            Orientation="Horizontal"
                                                                            VerticalAlignment="Center">
                                                                    <TextBlock x:Name="ModelNameText"
                                                                               Text="{Binding ModelName}"
                                                                               FontSize="11"
                                                                               Foreground="#99000000"
                                                                               VerticalAlignment="Center" />
                                                                    <Image Source="Assets/icon-chevron-right@3x.png"
                                                                           Width="20"
                                                                           Height="20"
                                                                           Margin="8,0,0,0" />
                                                                </StackPanel>
                                                            </Grid>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </ScrollViewer>

                                    <!-- No apps detected — layout matching login panel -->
                                    <Border x:Name="NoAppsPanel"
                                            Grid.Row="1"
                                            Padding="16"
                                            Visibility="{Binding NoAppsEmptyVisibility}">
                                        <StackPanel VerticalAlignment="Center">
                                            <StackPanel Margin="8,0,0,0">
                                                <Border Width="56" Height="56"
                                                        CornerRadius="28"
                                                        Background="White"
                                                        HorizontalAlignment="Left"
                                                        Margin="0,0,0,20">
                                                    <Image Source="Assets/login-hero.png"
                                                           Width="56" Height="56" />
                                                </Border>
                                                <TextBlock Text="未检测到可配置的应用"
                                                           FontSize="16"
                                                           FontWeight="Bold"
                                                           Foreground="#E0000000"
                                                           Margin="0,0,0,12" />
                                                <TextBlock Text="当前支持 Claude Code、OpenClaw、Hermes"
                                                           FontSize="12"
                                                           LineHeight="19"
                                                           Foreground="#FF333333"
                                                           TextWrapping="Wrap"
                                                           Margin="0,0,0,20" />
                                            </StackPanel>
                                            <StackPanel HorizontalAlignment="Left">
                                                <Button Content="重新检测应用"
                                                        Width="128"
                                                        Padding="12,0"
                                                        Height="32"
                                                        FontSize="13"
                                                        Style="{StaticResource PrimaryButtonStyle}"
                                                        Click="RefreshApps_Click" />
                                                <Button Content="部署OpenClaw"
                                                        Width="128"
                                                        Padding="12,0"
                                                        Height="32"
                                                        FontSize="13"
                                                        Margin="0,12,0,0"
                                                        Foreground="#E0000000"
                                                        Style="{StaticResource SecondaryButtonStyle}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Scanning state — same layout as NoAppsPanel, button replaced with loading bar -->
                                    <Border x:Name="ScanningPanel"
                                            Grid.Row="1"
                                            Padding="16"
                                            Visibility="Collapsed">
                                        <StackPanel VerticalAlignment="Center">
                                            <StackPanel Margin="8,0,0,0">
                                                <Border Width="56" Height="56"
                                                        CornerRadius="28"
                                                        Background="White"
                                                        HorizontalAlignment="Left"
                                                        Margin="0,0,0,20">
                                                    <Image Source="Assets/login-hero.png"
                                                           Width="56" Height="56" />
                                                </Border>
                                                <TextBlock Text="正在检测可配置应用"
                                                           FontSize="16"
                                                           FontWeight="Bold"
                                                           Foreground="#E0000000"
                                                           Margin="0,0,0,12" />
                                                <TextBlock Text="正在扫描本机已安装应用，识别 Token Hub 支持的工具"
                                                           FontSize="12"
                                                           LineHeight="22"
                                                           Foreground="#73000000"
                                                           TextWrapping="Wrap"
                                                           Margin="0,0,0,20" />
                                            </StackPanel>
                                            <Grid Height="32" ClipToBounds="True">
                                                <Border Background="#0A000000" CornerRadius="2"
                                                        Height="4" VerticalAlignment="Center" />
                                                <Border x:Name="ScanTrack"
                                                        Width="100" Height="4"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center"
                                                        Background="{StaticResource AccentBrush}"
                                                        CornerRadius="2"
                                                        RenderTransformOrigin="0.5,0.5">
                                                    <Border.RenderTransform>
                                                        <TranslateTransform x:Name="ScanSlide" />
                                                    </Border.RenderTransform>
                                                </Border>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>

                            <!-- ===== ACCOUNT BAR (Footer) ===== -->
                            <Border x:Name="AccountFooter"
                                    Grid.Row="1"
                                    Height="64"
                                    Padding="16,0"
                                    Background="#05292C33"
                                    BorderBrush="#14000000"
                                    BorderThickness="0,1,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Avatar -->
                                    <Image Grid.Column="0"
                                           Source="Assets/avatar@3x.png"
                                           Width="28"
                                           Height="28"
                                           Margin="0,0,12,0" />

                                    <!-- Account Info -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding PhoneNumber}"
                                                       FontSize="13"
                                                       Foreground="#FF1B1B1F"
                                                       VerticalAlignment="Center" />
                                            <Border x:Name="BalanceBadge"
                                                    Height="18"
                                                    CornerRadius="2"
                                                    Padding="5,1,5,0"
                                                    Margin="6,0,0,0"
                                                    Visibility="Collapsed"
                                                    Background="#FFF0C2"
                                                    VerticalAlignment="Center">
                                                <TextBlock x:Name="BalanceBadgeText"
                                                           FontSize="10"
                                                           FontWeight="Medium"
                                                           Foreground="#8A5700"
                                                           VerticalAlignment="Center"
                                                           TextOptions.TextFormattingMode="Display"
                                                           RenderTransformOrigin="0.5,0.5">
                                                    <TextBlock.RenderTransform>
                                                        <TranslateTransform Y="-0.5" />
                                                    </TextBlock.RenderTransform>
                                                </TextBlock>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding BalanceText}"
                                                   FontSize="12"
                                                   Foreground="#73000000"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>

                                    <Grid Grid.Column="2" />

                                    <!-- More Button -->
                                    <Button x:Name="MoreButton"
                                            Grid.Column="3"
                                            Width="20"
                                            Height="20"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            VerticalAlignment="Center"
                                            Margin="0,0,12,0"
                                            Click="MoreButton_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" CornerRadius="4" Background="Transparent">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#0A000000" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <Image Source="Assets/icon-more@3x.png"
                                               Width="20"
                                               Height="20" />
                                    </Button>
                                    <!-- Account menu dropdown -->
                                    <Popup x:Name="AccountMenuPopup"
                                           PlacementTarget="{Binding ElementName=MoreButton}"
                                           Placement="Top"
                                           VerticalOffset="-4"
                                           StaysOpen="False"
                                           AllowsTransparency="True"
                                           PopupAnimation="Fade"
                                           Opened="AccountMenuPopup_Opened">
                                        <Border Style="{StaticResource FlyoutMenuBorderStyle}" Width="140" Margin="8">
                                            <StackPanel>
                                                <Button Content="我的账户" Style="{StaticResource FlyoutMenuItemStyle}" Tag="account" Click="WebLink_Click" />
                                                <Button Content="登出" Style="{StaticResource FlyoutMenuItemDangerStyle}" Click="Logout_Click" />
                                            </StackPanel>
                                        </Border>
                                    </Popup>

                                    <!-- Recharge Button -->
                                    <Button Grid.Column="4"
                                            Content="充值"
                                            Style="{StaticResource RechargeButtonStyle}"
                                            VerticalAlignment="Center"
                                            Click="RechargeButton_Click" />
                                </Grid>
                            </Border>

                            <!-- Logged-out Footer — hidden per visual demo (login panel has its own 登录 button) -->
                            <Border x:Name="LoggedOutFooter"
                                    Grid.Row="1"
                                    Visibility="Collapsed"
                                    Height="64"
                                    Padding="16,0"
                                    Background="#05292C33"
                                    BorderBrush="#14000000"
                                    BorderThickness="0,1,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Width="28"
                                            Height="28"
                                            CornerRadius="14"
                                            Background="#EBEAF3FF"
                                            Margin="0,0,12,0">
                                        <TextBlock Text="1"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   Foreground="#FF315FAA"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="登录联想账户"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   Foreground="#FF1B1B1F" />
                                        <TextBlock Text="同步额度并使用模型服务"
                                                   FontSize="12"
                                                   Foreground="#99000000"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>

                                    <Button Grid.Column="2"
                                            Content="登录"
                                            Height="28"
                                            Padding="9,0"
                                            FontSize="11"
                                            Background="#ADFFFFFF"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            VerticalAlignment="Center"
                                            Click="LoginFromFooter_Click" />
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- ===== MODELS PAGE ===== -->
                        <Grid x:Name="ModelsPage" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- Detail Header -->
                            <Border Grid.Row="0"
                                    Height="48"
                                    Padding="4,0,16,0"
                                    Background="Transparent"
                                    BorderBrush="#14000000"
                                    BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Width="40"
                                            Height="40"
                                            Margin="0,0,4,0"
                                            Style="{StaticResource Win11TitleBarIconButtonStyle}"
                                            Click="BackToHome_Click">
                                        <Image Source="Assets/panel-back@3x.png"
                                               Width="40"
                                               Height="40" />
                                    </Button>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding DetailToolName}"
                                               FontSize="14"
                                               FontWeight="Regular"
                                               Foreground="#FF1B1B1F"
                                               VerticalAlignment="Center" />

                                    <Button Grid.Column="2"
                                            Width="20"
                                            Height="20"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Click="CloseButton_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" CornerRadius="4" Background="Transparent">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#0A000000" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <Image Source="Assets/panel-close@3x.png"
                                               Width="20"
                                               Height="20" />
                                    </Button>
                                </Grid>
                            </Border>

                            <!-- Model List -->
                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Hidden"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Padding="0,8,0,0">
                                <ScrollViewer.Resources>
                                    <Style TargetType="ScrollBar" BasedOn="{StaticResource ThinScrollBarStyle}" />
                                </ScrollViewer.Resources>
                                <ItemsControl x:Name="ModelListControl"
                                              ItemsSource="{Binding CurrentModels}"
                                              HorizontalContentAlignment="Stretch">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="models:ModelInfo">
                                            <Border Height="80"
                                                    Padding="0"
                                                    HorizontalAlignment="Stretch"
                                                    Background="Transparent"
                                                    CornerRadius="4"
                                                    Cursor="Hand"
                                                    MouseLeftButtonDown="ModelItem_Click"
                                                    Loaded="ModelRow_Loaded"
                                                    Tag="{Binding Id}">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Opacity" Value="1" />
                                                        <Setter Property="Cursor" Value="Hand" />
                                                        <Setter Property="Background" Value="Transparent" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding DataContext.IsSmartMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                                <Setter Property="Opacity" Value="0.38" />
                                                                <Setter Property="Cursor" Value="Arrow" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid HorizontalAlignment="Stretch">
                                                    <!-- Hover overlay (behind content, full width) -->
                                                    <Border x:Name="ModelHoverBg"
                                                            HorizontalAlignment="Stretch"
                                                            Background="Transparent"
                                                            CornerRadius="4"
                                                            IsHitTestVisible="False" />
                                                    <!-- Sweep shine overlay (on top) -->
                                                    <Border x:Name="ModelSweep"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Stretch"
                                                            Visibility="Hidden"
                                                            Opacity="0"
                                                            IsHitTestVisible="False">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                                <GradientStop Offset="0" Color="#00FFFFFF" />
                                                                <GradientStop Offset="0.5" Color="#0DFFFFFF" />
                                                                <GradientStop Offset="1" Color="#00FFFFFF" />
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                    <Grid Margin="16,8,16,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Radio Button 20x20 -->
                                                    <Border x:Name="RadioOuter"
                                                            Grid.Column="0"
                                                            Width="20"
                                                            Height="20"
                                                            CornerRadius="10"
                                                            BorderThickness="1"
                                                            BorderBrush="#9B000000"
                                                            Background="#05000000"
                                                            VerticalAlignment="Center">
                                                        <Ellipse x:Name="RadioBullet"
                                                                 Width="10"
                                                                 Height="10"
                                                                 Fill="Transparent" />
                                                    </Border>

                                                    <!-- Model Info -->
                                                    <StackPanel Grid.Column="1"
                                                                Margin="16,0,0,0"
                                                                VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="14"
                                                                   Foreground="#E0000000" />
                                                        <TextBlock Margin="0,4,0,0"
                                                                   FontSize="12"
                                                                   Foreground="#99000000"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   TextWrapping="NoWrap">
                                                            <Run Text="输入" />
                                                            <Run Text="{Binding InputPrice}" />
                                                            <Run Text="  输出" />
                                                            <Run Text="{Binding OutputPrice}" />
                                                            <Run Text="  缓存读取" />
                                                            <Run Text="{Binding CachePrice}" />
                                                            <Run Text="/1M" />
                                                        </TextBlock>
                                                        <ItemsControl ItemsSource="{Binding Tags}"
                                                                      Margin="0,4,0,0">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Orientation="Horizontal" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Height="17"
                                                                            Padding="4,0"
                                                                            CornerRadius="2"
                                                                            Background="#CFE3F3"
                                                                            Margin="0,0,4,0">
                                                                        <TextBlock Text="{Binding}"
                                                                                   FontSize="11"
                                                                                   Foreground="{StaticResource NotificationTagTextBrush}"
                                                                                   VerticalAlignment="Center" />
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                    <Border x:Name="ModelBadge"
                                                            Grid.Column="2"
                                                            Height="22"
                                                            CornerRadius="4"
                                                            Padding="8,0"
                                                            Margin="16,0,0,0"
                                                            Background="Transparent"
                                                            VerticalAlignment="Center"
                                                            Visibility="Collapsed">
                                                        <TextBlock x:Name="ModelBadgeText"
                                                                   Text="当前模型"
                                                                   FontSize="11"
                                                                   FontWeight="Medium"
                                                                   Foreground="{StaticResource AccentTagBrush}"
                                                                   VerticalAlignment="Center" />
                                                    </Border>
                                                    </Grid>
                                                </Grid>
                                                </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>

                        <!-- ===== SETTINGS PAGE ===== -->
                        <Grid x:Name="SettingsPage" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- Settings Header -->
                            <Border Grid.Row="0"
                                    Height="48"
                                    Padding="4,0,16,0"
                                    Background="Transparent"
                                    BorderBrush="#14000000"
                                    BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Width="40"
                                            Height="40"
                                            Margin="0,0,4,0"
                                            Style="{StaticResource Win11TitleBarIconButtonStyle}"
                                            Click="BackToHome_Click">
                                        <Image Source="Assets/panel-back@3x.png"
                                               Width="40"
                                               Height="40" />
                                    </Button>

                                    <TextBlock Grid.Column="1"
                                               Text="设置"
                                               FontSize="14"
                                               FontWeight="Regular"
                                               Foreground="#FF1B1B1F"
                                               VerticalAlignment="Center" />

                                    <Button Grid.Column="2"
                                            Width="20"
                                            Height="20"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Click="CloseButton_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" CornerRadius="4" Background="Transparent">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#0A000000" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <Image Source="Assets/panel-close@3x.png"
                                               Width="20"
                                               Height="20" />
                                    </Button>
                                </Grid>
                            </Border>

                            <!-- Settings List -->
                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel>
                                    <!-- 开机自启 -->
                                    <Border Height="64"
                                            Padding="16,0"
                                            BorderBrush="#A4D9DEE8"
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="开机自启" FontSize="14" Foreground="#E0000000" />
                                                <TextBlock Text="登录 Windows 后自动运行" FontSize="12" Foreground="#99000000" Margin="0,4,0,0" />
                                            </StackPanel>
                                            <ToggleButton Grid.Column="1"
                                                          Style="{StaticResource WindowsNativeSwitchStyle}"
                                                          IsChecked="True"
                                                          VerticalAlignment="Center"
                                                          ToolTip="开机自启" />
                                        </Grid>
                                    </Border>

                                    <!-- 系统通知 -->
                                    <Border Height="64"
                                            Padding="16,0"
                                            BorderBrush="#A4D9DEE8"
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="系统通知" FontSize="14" Foreground="#E0000000" />
                                                <TextBlock Text="发现新应用和切换异常时提醒" FontSize="12" Foreground="#99000000" Margin="0,4,0,0" />
                                            </StackPanel>
                                            <ToggleButton Grid.Column="1"
                                                          Style="{StaticResource WindowsNativeSwitchStyle}"
                                                          IsChecked="True"
                                                          VerticalAlignment="Center"
                                                          ToolTip="系统通知" />
                                        </Grid>
                                    </Border>

                                    <!-- 自动检测新应用 -->
                                    <Border Height="64"
                                            Padding="16,0"
                                            BorderBrush="#A4D9DEE8"
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="自动检测新应用" FontSize="14" Foreground="#E0000000" />
                                                <TextBlock Text="安装应用后自动加入列表" FontSize="12" Foreground="#99000000" Margin="0,4,0,0" />
                                            </StackPanel>
                                            <ToggleButton Grid.Column="1"
                                                          Style="{StaticResource WindowsNativeSwitchStyle}"
                                                          IsChecked="True"
                                                          VerticalAlignment="Center"
                                                          ToolTip="自动检测新应用" />
                                        </Grid>
                                    </Border>

                                    <!-- 版本号 -->
                                    <Border Height="64" Padding="16,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="版本号" FontSize="14" Foreground="#E0000000" />
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock Text="v2.0.4" FontSize="12" Foreground="#99000000" />
                                                    <TextBlock Text="新版本 2.1.0" FontSize="12" Foreground="#005FB8"
                                                               FontWeight="Medium" Margin="12,0,0,0"
                                                               Visibility="{Binding NewVersionBadgeVisibility}" />
                                                </StackPanel>
                                            </StackPanel>
                                            <!-- 检查更新 (default, white) -->
                                            <Button Grid.Column="1"
                                                    Width="72" Height="30" FontSize="13"
                                                    Foreground="#CC1B1B1F"
                                                    Cursor="Hand"
                                                    Click="CheckUpdate_Click"
                                                    Visibility="{Binding CheckUpdateButtonVisibility}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="#B3FFFFFF" CornerRadius="15"
                                                                BorderThickness="1" BorderBrush="#1A000000">
                                                            <Grid>
                                                                <TextBlock x:Name="UpdateBtnText"
                                                                           Text="检查更新"
                                                                           FontSize="13"
                                                                           Foreground="#CC1B1B1F"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center" />
                                                                <TextBlock x:Name="UpdateBtnSpinner"
                                                                           Text="&#xE895;"
                                                                           FontFamily="Segoe MDL2 Assets"
                                                                           FontSize="14"
                                                                           Foreground="#CC1B1B1F"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Visibility="Collapsed"
                                                                           RenderTransformOrigin="0.5,0.5">
                                                                    <TextBlock.RenderTransform>
                                                                        <RotateTransform x:Name="CheckUpdateSpinner" />
                                                                    </TextBlock.RenderTransform>
                                                                </TextBlock>
                                                            </Grid>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <!-- 立即更新 (when new version, accent) -->
                                            <Button Grid.Column="1"
                                                    Content="立即更新"
                                                    Height="30" Padding="10,0" FontSize="13"
                                                    Background="#005FB8"
                                                    Foreground="White"
                                                    BorderBrush="#14FFFFFF"
                                                    BorderThickness="1"
                                                    Cursor="Hand"
                                                    Click="DoUpdate_Click"
                                                    Visibility="{Binding NewVersionBadgeVisibility}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="bd"
                                                                Background="{TemplateBinding Background}"
                                                                CornerRadius="15"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="bd" Property="Background" Value="#004C99" />
                                                            </Trigger>
                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter TargetName="bd" Property="Background" Value="#003E7E" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Grid>

                    <!-- ===== TOAST ===== -->
                    <Border x:Name="ToastBorder"
                            Grid.Row="0"
                            Grid.RowSpan="3"
                            CornerRadius="4"
                            Background="#F01F232A"
                            Padding="13,8"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Margin="0,54,0,0"
                            Visibility="Collapsed"
                            Effect="{StaticResource MenuShadow}">
                        <TextBlock x:Name="ToastText"
                                   Text=""
                                   FontSize="12"
                                   Foreground="White" />
                    </Border>
                </Grid>
                </Border><!-- /inner clip border -->
        </Border>

        <!-- ===== NOTIFICATION POPUP ===== -->
        <!-- Lives at root Grid level — outside InnerClipBorder's Clip geometry -->
        <Border x:Name="NotificationPanel"
                Width="{StaticResource NotificationCardWidth}"
                CornerRadius="{StaticResource NotificationCornerRadius}"
                BorderBrush="{StaticResource NotificationStrokeBrush}"
                BorderThickness="1"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="16,8,16,24"
                Visibility="Collapsed"
                RenderTransformOrigin="0.5,0.5"
                MouseLeftButtonUp="NotificationPanel_MouseLeftButtonUp"
                Effect="{StaticResource NotificationShadow}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="{StaticResource NotificationSurfaceBrush}" />
                    <Setter Property="Cursor" Value="Hand" />
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource NotificationSurfaceHoverBrush}" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border.RenderTransform>
                <ScaleTransform x:Name="NotificationScale" ScaleX="1" ScaleY="1" />
            </Border.RenderTransform>
            <Grid Margin="{StaticResource NotificationContentMargin}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0"
                       Source="Assets/notification-app-icon@3x.png"
                       Width="{StaticResource NotificationAppIconSize}"
                       Height="{StaticResource NotificationAppIconSize}"
                       VerticalAlignment="Top"
                       Margin="0,10,0,0" />

                <!-- Auto Discovery Body (smart match ON) -->
                <StackPanel x:Name="AutoNotificationBody"
                            Grid.Column="1"
                            Margin="{StaticResource NotificationTextColumnMargin}">
                    <TextBlock FontSize="{StaticResource NotificationTitleFontSize}"
                               FontWeight="Bold"
                               Foreground="{StaticResource NotificationTitleTextBrush}"
                               LineHeight="{StaticResource NotificationTitleLineHeight}"
                               TextTrimming="CharacterEllipsis">
                        <Run Text="{Binding DiscoveryToolName}" />
                        <Run Text=" 已完成模型匹配" />
                    </TextBlock>
                    <TextBlock FontSize="{StaticResource NotificationBodyFontSize}"
                               Foreground="{StaticResource NotificationBodyTextBrush}"
                               Margin="{StaticResource NotificationBodyTextMargin}"
                               LineHeight="{StaticResource NotificationBodyLineHeight}"
                               TextTrimming="CharacterEllipsis">
                        <Run Text="已智能匹配 " />
                        <Run Text="{Binding DiscoveryModelName}" />
                        <Run Text="，可直接使用" />
                    </TextBlock>
                    <ItemsControl ItemsSource="{Binding DiscoveryTags}"
                                  Margin="{StaticResource NotificationTagListMargin}">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Style.Triggers>
                                    <Trigger Property="HasItems" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border MinHeight="{StaticResource NotificationTagHeight}"
                                        Padding="{StaticResource NotificationTagPadding}"
                                        CornerRadius="{StaticResource NotificationTagCornerRadius}"
                                        Background="{StaticResource NotificationTagBackgroundBrush}"
                                        Margin="{StaticResource NotificationTagMargin}">
                                    <TextBlock Text="{Binding}"
                                               FontSize="{StaticResource NotificationTagFontSize}"
                                               LineHeight="{StaticResource NotificationTagLineHeight}"
                                               Foreground="{StaticResource NotificationTagTextBrush}"
                                               VerticalAlignment="Center" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Manual Discovery Body (smart match OFF) -->
                <StackPanel x:Name="ManualNotificationBody"
                            Grid.Column="1"
                            Margin="{StaticResource NotificationTextColumnMargin}">
                    <TextBlock FontSize="{StaticResource NotificationTitleFontSize}"
                               FontWeight="Bold"
                               Foreground="{StaticResource NotificationTitleTextBrush}"
                               LineHeight="{StaticResource NotificationTitleLineHeight}"
                               TextTrimming="CharacterEllipsis">
                        <Run Text="发现新应用 " />
                        <Run Text="{Binding DiscoveryToolName}" />
                    </TextBlock>
                    <TextBlock Text="点击选择模型即可使用"
                               FontSize="{StaticResource NotificationBodyFontSize}"
                               Foreground="{StaticResource NotificationBodyTextBrush}"
                               Margin="{StaticResource NotificationBodyTextMargin}"
                               LineHeight="{StaticResource NotificationBodyLineHeight}"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <!-- More (⋯) button -->
                <Button x:Name="NotificationSettingButton"
                        Grid.Column="2"
                        VerticalAlignment="Top"
                        Margin="{StaticResource NotificationFirstActionButtonMargin}"
                        Style="{StaticResource NotificationIconButtonStyle}"
                        Click="NotificationSettingButton_Click">
                    <Image Width="16" Height="16"
                           Source="Assets/notification-more@3x.png"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                </Button>

                <!-- Close (×) button -->
                <Button x:Name="NotificationCloseButton"
                        Grid.Column="3"
                        VerticalAlignment="Top"
                        Margin="{StaticResource NotificationActionButtonMargin}"
                        Style="{StaticResource NotificationIconButtonStyle}"
                        Click="DismissNotification_Click">
                    <Image Width="16" Height="16"
                           Source="Assets/notification-close@3x.png"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                </Button>

                <Border x:Name="NotificationActions" Visibility="Collapsed" />
            </Grid>
        </Border>

        <!-- ===== TRAY CONTEXT MENU (Figma 632:641) ===== -->
        <Popup x:Name="TrayMenuPopup"
               Placement="Absolute"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Fade"
               Opened="TrayMenuPopup_Opened">
            <Border Width="156"
                    CornerRadius="7"
                    Background="White"
                    BorderBrush="#1A000000"
                    BorderThickness="1"
                    Effect="{StaticResource TrayMenuShadow}">
                <StackPanel x:Name="TrayMenuItems" Margin="5,3">
                    <!-- 刷新应用 -->
                    <Border x:Name="TrayMenuItem1"
                            Height="30"
                            CornerRadius="3"
                            Padding="14,0"
                            Background="Transparent"
                            Cursor="Hand"
                            MouseLeftButtonDown="TrayMenuRefresh_Click"
                            MouseEnter="TrayMenuItem_MouseEnter"
                            MouseLeave="TrayMenuItem_MouseLeave">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="Assets/icon-action@3x.png" Width="16" Height="16" Margin="0,0,10,0" />
                            <TextBlock Text="刷新应用" FontSize="12" Foreground="#E0000000" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <!-- 设置 -->
                    <Border x:Name="TrayMenuItem2"
                            Height="30"
                            CornerRadius="3"
                            Padding="14,0"
                            Background="Transparent"
                            Cursor="Hand"
                            MouseLeftButtonDown="TrayMenuSettings_Click"
                            MouseEnter="TrayMenuItem_MouseEnter"
                            MouseLeave="TrayMenuItem_MouseLeave">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="Assets/tray-settings@3x.png" Width="16" Height="16" Margin="0,0,10,0" />
                            <TextBlock Text="设置" FontSize="12" Foreground="#E0000000" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <!-- 退出 -->
                    <Border x:Name="TrayMenuItem3"
                            Height="30"
                            CornerRadius="3"
                            Padding="14,0"
                            Background="Transparent"
                            Cursor="Hand"
                            MouseLeftButtonDown="TrayMenuExit_Click"
                            MouseEnter="TrayMenuItem_MouseEnter"
                            MouseLeave="TrayMenuItem_MouseLeave">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="Assets/tray-close@3x.png" Width="16" Height="16" Margin="0,0,10,0" />
                            <TextBlock Text="退出" FontSize="12" Foreground="#E0000000" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
