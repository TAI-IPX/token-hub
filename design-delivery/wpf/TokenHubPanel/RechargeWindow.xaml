<Window x:Class="TokenHubPanel.RechargeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="充值"
        FontFamily="Microsoft YaHei"
        FontSize="14"
        Width="760"
        Height="560"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <!-- Amount card -->
        <Style x:Key="AmountCardStyle" TargetType="Button">
            <Setter Property="Height" Value="68" />
            <Setter Property="FontSize" Value="19" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#15181D" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Card"
                                Background="#F6F7FA"
                                BorderBrush="#E0E4EA"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14,0">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Card" Property="Background" Value="#EEF6FF" />
                                <Setter TargetName="Card" Property="BorderBrush" Value="#176FC4" />
                            </Trigger>
                            <Trigger Property="Tag" Value="active">
                                <Setter TargetName="Card" Property="Background" Value="#EEF6FF" />
                                <Setter TargetName="Card" Property="BorderBrush" Value="#176FC4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Pay tab -->
        <Style x:Key="PayTabStyle" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#555D67" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Tab" Background="Transparent" CornerRadius="99">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="active">
                                <Setter TargetName="Tab" Property="Background" Value="White" />
                                <Setter Property="Foreground" Value="#111111" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="9"
            Background="White"
            BorderBrush="#33000000"
            BorderThickness="1"
            Effect="{StaticResource PanelShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="#EBF2F4F8" CornerRadius="9,9,0,0" MouseLeftButtonDown="TitleBar_DragMove">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                        <Image Source="Assets/desktop-token-hub-icon@3x.png" Width="19" Height="19" Margin="0,0,8,0" />
                        <TextBlock Text="充值" FontSize="12" FontWeight="Medium" Foreground="#1B1B1F" VerticalAlignment="Center" />
                    </StackPanel>
                    <Button Grid.Column="2" Width="46" Height="40" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Click="Close_Click" Content="&#x00D7;" FontSize="16" Foreground="#3F4650">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="CloseBg" Background="{TemplateBinding Background}" CornerRadius="0,9,0,0">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="CloseBg" Property="Background" Value="#C42B1C" />
                                        <Setter Property="Foreground" Value="White" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="26,22">

                <!-- ===== AMOUNT VIEW ===== -->
                <ScrollViewer x:Name="AmountView" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Head -->
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="42" Height="42" CornerRadius="21" Background="#EEF6FF" Margin="0,0,12,0">
                                    <TextBlock Text="&#xE1D0;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                               Foreground="#176FC4" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="充值" FontSize="22" FontWeight="Bold" Foreground="#15181D" />
                                    <TextBlock Text="选择金额和支付方式" FontSize="13" Foreground="#5E626A" Margin="0,2,0,0" />
                                </StackPanel>
                            </StackPanel>
                            <Button Content="订单历史" HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Height="32" Padding="12,0" FontSize="12" Cursor="Hand"
                                    Tag="account" Click="WebLink_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="White" BorderBrush="#DCE0E6" BorderThickness="1" CornerRadius="99" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <!-- Amount grid -->
                        <TextBlock Text="金额" FontSize="13" FontWeight="Bold" Foreground="#5B626C" Margin="0,20,0,10" />
                        <UniformGrid x:Name="AmountGrid" Columns="3" Rows="2">
                            <Button Content="10元" Tag="" Style="{StaticResource AmountCardStyle}" Margin="0,0,10,10" Click="AmountCard_Click" />
                            <Button Content="20元" Tag="" Style="{StaticResource AmountCardStyle}" Margin="0,0,10,10" Click="AmountCard_Click" />
                            <Button Content="50元" Tag="active" Style="{StaticResource AmountCardStyle}" Margin="0,0,0,10" Click="AmountCard_Click" />
                            <Button Content="100元" Tag="" Style="{StaticResource AmountCardStyle}" Margin="0,0,10,0" Click="AmountCard_Click" />
                            <Button Content="200元" Tag="" Style="{StaticResource AmountCardStyle}" Margin="0,0,10,0" Click="AmountCard_Click" />
                            <Button Content="500元" Tag="" Style="{StaticResource AmountCardStyle}" Margin="0,0,0,0" Click="AmountCard_Click" />
                        </UniformGrid>

                        <!-- Custom amount -->
                        <TextBlock Text="自定义金额" FontSize="13" FontWeight="Bold" Foreground="#5B626C" Margin="0,20,0,10" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="150" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Height="38" BorderBrush="#DFE3E8" BorderThickness="1" CornerRadius="8" Margin="0,0,10,0">
                                <TextBox x:Name="CustomAmountBox" Text="50" BorderThickness="0" Background="Transparent"
                                         VerticalContentAlignment="Center" Padding="12,0" FontSize="13"
                                         TextChanged="CustomAmount_TextChanged" />
                            </Border>
                            <Border Grid.Column="1" Height="38" BorderBrush="#DFE3E8" BorderThickness="1" CornerRadius="8" Padding="12,0">
                                <Grid>
                                    <TextBlock Text="待支付金额：" FontSize="12" Foreground="#6B7280" VerticalAlignment="Center" HorizontalAlignment="Left" />
                                    <TextBlock x:Name="AmountTotalText" Text="¥50.00" FontSize="13" FontWeight="Bold" Foreground="#15181D" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Payment method -->
                        <TextBlock Text="付款方式" FontSize="13" FontWeight="Bold" Foreground="#5B626C" Margin="0,20,0,10" />
                        <Border Width="330" Height="38" HorizontalAlignment="Left" BorderBrush="#DFE3E8" BorderThickness="1" CornerRadius="8" Background="#F7F8FB" Padding="13,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xE1D0;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#EF1F1F" Margin="0,0,9,0" VerticalAlignment="Center" />
                                <TextBlock Text="微信/支付宝" FontSize="13" FontWeight="SemiBold" Foreground="#15181D" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <!-- Footer -->
                        <Border BorderBrush="#E8EBEF" BorderThickness="0,1,0,0" Margin="0,22,0,0" Padding="0,16,0,0">
                            <Button Content="确认付款" HorizontalAlignment="Right" Height="34" Padding="16,0" FontSize="13"
                                    Style="{StaticResource PrimaryButtonStyle}" Click="ToConfirm_Click" />
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- ===== CONFIRM VIEW ===== -->
                <Grid x:Name="ConfirmView" Visibility="Collapsed">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="42" Height="42" CornerRadius="21" Background="#EEF6FF" Margin="0,0,12,0">
                                <TextBlock Text="&#xE1D0;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="#176FC4" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="确认付款" FontSize="22" FontWeight="Bold" Foreground="#15181D" />
                                <TextBlock Text="查看您的付款详情" FontSize="13" Foreground="#5E626A" Margin="0,2,0,0" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Margin="0,26,0,0">
                            <Grid Margin="0,0,0,20">
                                <TextBlock Text="充值金额" FontSize="16" Foreground="#5D646D" HorizontalAlignment="Left" />
                                <TextBlock x:Name="ConfirmAmount1" Text="¥50.00" FontSize="22" FontWeight="Bold" Foreground="#101216" HorizontalAlignment="Right" />
                            </Grid>
                            <Grid Margin="0,0,0,20">
                                <TextBlock Text="您支付" FontSize="16" Foreground="#5D646D" HorizontalAlignment="Left" />
                                <TextBlock x:Name="ConfirmAmount2" Text="50.00" FontSize="22" FontWeight="Bold" Foreground="#101216" HorizontalAlignment="Right" />
                            </Grid>
                            <Grid>
                                <TextBlock Text="付款方式" FontSize="16" Foreground="#5D646D" HorizontalAlignment="Left" />
                                <TextBlock Text="微信/支付宝" FontSize="16" Foreground="#101216" HorizontalAlignment="Right" />
                            </Grid>
                        </StackPanel>
                        <Border BorderBrush="#E8EBEF" BorderThickness="0,1,0,0" Margin="0,28,0,0" Padding="0,16,0,0">
                            <Button Content="去支付" HorizontalAlignment="Right" Height="34" Padding="16,0" FontSize="13"
                                    Style="{StaticResource PrimaryButtonStyle}" Click="ToPay_Click" />
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- ===== PAY / DETAIL VIEW ===== -->
                <Grid x:Name="PayView" Visibility="Collapsed">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="42" Height="42" CornerRadius="21" Background="#EEF6FF" Margin="0,0,12,0">
                                <TextBlock Text="&#xE1D0;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="#176FC4" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="扫码支付" FontSize="22" FontWeight="Bold" Foreground="#15181D" />
                                <TextBlock Text="请使用手机 app 完成支付" FontSize="13" Foreground="#5E626A" Margin="0,2,0,0" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Tabs -->
                        <Border Background="#F0F1F3" CornerRadius="99" Padding="4" Margin="0,16,0,0" HorizontalAlignment="Center" Width="240">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button x:Name="TabQr" Grid.Column="0" Content="二维码" Tag="active" Style="{StaticResource PayTabStyle}" Click="TabQr_Click" />
                                <Button x:Name="TabDetail" Grid.Column="1" Content="详情" Tag="" Style="{StaticResource PayTabStyle}" Click="TabDetail_Click" />
                            </Grid>
                        </Border>

                        <!-- QR / Detail box -->
                        <Border MinHeight="276" BorderBrush="#E1E5EB" BorderThickness="1" CornerRadius="14" Margin="0,16,0,0">
                            <Grid>
                                <!-- QR -->
                                <StackPanel x:Name="QrBox" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Border Width="184" Height="184" Background="White" BorderBrush="#E1E5EB" BorderThickness="12" CornerRadius="10"
                                            Effect="{StaticResource MenuShadow}" HorizontalAlignment="Center">
                                        <Viewbox>
                                            <TextBlock Text="&#xE8B8;" FontFamily="Segoe MDL2 Assets" Foreground="#111111" />
                                        </Viewbox>
                                    </Border>
                                    <TextBlock Text="等待支付..." FontSize="13" FontWeight="Bold" Foreground="#62666D" HorizontalAlignment="Center" Margin="0,13,0,0" />
                                    <TextBlock Text="扫描 聚合码" FontSize="13" Foreground="#62666D" HorizontalAlignment="Center" Margin="0,3,0,0" />
                                    <TextBlock Text="到期时间：2026/6/1 10:46:33" FontSize="13" Foreground="#62666D" HorizontalAlignment="Center" Margin="0,3,0,0" />
                                </StackPanel>
                                <!-- Detail -->
                                <StackPanel x:Name="DetailBox" Visibility="Collapsed" VerticalAlignment="Center" Margin="24">
                                    <Grid Margin="0,0,0,18">
                                        <TextBlock Text="金额" FontSize="15" Foreground="#62666D" HorizontalAlignment="Left" />
                                        <TextBlock x:Name="DetailAmount" Text="¥50.00" FontSize="18" FontWeight="Bold" Foreground="#D91E2B" HorizontalAlignment="Right" />
                                    </Grid>
                                    <Grid Margin="0,0,0,18">
                                        <TextBlock Text="订单编号" FontSize="15" Foreground="#62666D" HorizontalAlignment="Left" />
                                        <TextBlock x:Name="DetailOrderId" Text="lenovo_75f4bae6_121" FontSize="18" FontWeight="Bold" Foreground="#111111" HorizontalAlignment="Right" />
                                    </Grid>
                                    <Grid Margin="0,0,0,18">
                                        <TextBlock Text="付款方式" FontSize="15" Foreground="#62666D" HorizontalAlignment="Left" />
                                        <TextBlock Text="聚合码" FontSize="18" FontWeight="Bold" Foreground="#111111" HorizontalAlignment="Right" />
                                    </Grid>
                                    <Grid>
                                        <TextBlock Text="到期时间" FontSize="15" Foreground="#62666D" HorizontalAlignment="Left" />
                                        <TextBlock Text="2026/6/1 10:46:33" FontSize="18" FontWeight="Bold" Foreground="#111111" HorizontalAlignment="Right" />
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border BorderBrush="#E8EBEF" BorderThickness="0,1,0,0" Margin="0,22,0,0" Padding="0,16,0,0">
                            <Button Content="模拟支付完成" HorizontalAlignment="Right" Height="34" Padding="16,0" FontSize="13"
                                    Style="{StaticResource PrimaryButtonStyle}" Click="CompletePay_Click" />
                        </Border>
                    </StackPanel>
                </Grid>

            </Grid>
        </Grid>
    </Border>
</Window>
