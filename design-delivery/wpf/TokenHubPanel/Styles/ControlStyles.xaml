    <!-- ScrollBar Style (thin 4px, hidden until hover) -->
    <Style x:Key="ThinScrollBarStyle" TargetType="ScrollBar">
        <Setter Property="Width" Value="4" />
        <Setter Property="Opacity" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent" Margin="0,0,0,8">
                        <Track Name="PART_Track"
                               Orientation="{TemplateBinding Orientation}"
                               IsDirectionReversed="False">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Width="0" Height="0">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton" />
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Width="0" Height="0">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton" />
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Width="4">
                                    <Thumb.Template>
                                        <ControlTemplate>
                                            <Border Background="#4D000000"
                                                    CornerRadius="2" />
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Opacity" Value="1" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Radio Button Template -->
    <Style x:Key="ModelRadioStyle" TargetType="RadioButton">
        <Setter Property="Width" Value="20" />
        <Setter Property="Height" Value="20" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid>
                        <Ellipse x:Name="OuterCircle"
                                 Width="20" Height="20"
                                 Stroke="#9B000000"
                                 StrokeThickness="1"
                                 Fill="#05000000" />
                        <Ellipse x:Name="InnerBullet"
                                 Width="10" Height="10"
                                 Fill="Transparent"
                                 Stroke="Transparent"
                                 StrokeThickness="0" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="OuterCircle" Property="Fill" Value="{StaticResource AccentBrush}" />
                            <Setter TargetName="OuterCircle" Property="Stroke" Value="{StaticResource AccentBrush}" />
                            <Setter TargetName="InnerBullet" Property="Fill" Value="White" />
                            <Setter TargetName="InnerBullet" Property="Stroke" Value="#0F000000" />
                            <Setter TargetName="InnerBullet" Property="StrokeThickness" Value="1" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Tag Style -->
    <Style x:Key="TagTextStyle" TargetType="TextBlock">
        <Setter Property="Height" Value="16" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Foreground" Value="#F59E0B" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0" />
    </Style>

    <!-- Setting Row -->
    <Style x:Key="SettingRowStyle" TargetType="Border">
        <Setter Property="Height" Value="64" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="BorderBrush" Value="#A4D9DEE8" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <!-- Flyout menu container (Windows 11 Fluent) -->
    <Style x:Key="FlyoutMenuBorderStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Background" Value="#F7F9FBFF" />
        <Setter Property="BorderBrush" Value="#14000000" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="Effect" Value="{StaticResource MenuShadow}" />
    </Style>

    <!-- Flyout menu item -->
    <Style x:Key="FlyoutMenuItemStyle" TargetType="Button">
        <Setter Property="Height" Value="36" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontFamily" Value="{StaticResource DefaultFont}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="#E51B1B1F" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <Border.Background>
                            <SolidColorBrush x:Name="FlyoutBg" Color="#00000000"/>
                        </Border.Background>
                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <ColorAnimation Storyboard.TargetName="FlyoutBg"
                                                    Storyboard.TargetProperty="Color"
                                                    To="#0D000000" Duration="0:0:0.12"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <ColorAnimation Storyboard.TargetName="FlyoutBg"
                                                    Storyboard.TargetProperty="Color"
                                                    To="#00000000" Duration="0:0:0.12"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Flyout menu item — danger variant -->
    <Style x:Key="FlyoutMenuItemDangerStyle" TargetType="Button" BasedOn="{StaticResource FlyoutMenuItemStyle}">
        <Setter Property="Foreground" Value="#C42B1C" />
    </Style>

</ResourceDictionary>
