    <!-- Recharge button: neutral by default, primary only when balance is insufficient -->
    <Style x:Key="RechargeButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="32" />
        <Setter Property="Foreground" Value="#CC1B1B1F" />
        <Setter Property="Background" Value="#B3FFFFFF" />
        <Setter Property="BorderBrush" Value="#1A000000" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontFamily" Value="{StaticResource DefaultFont}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#EEF1F6" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#DEE2E9" />
                        </Trigger>
                        <DataTrigger Binding="{Binding IsLowBalance}" Value="True">
                            <Setter Property="Background" Value="#005FB8" />
                            <Setter Property="BorderBrush" Value="#14FFFFFF" />
                            <Setter Property="Foreground" Value="White" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Full-width primary button for onboarding -->
    <Style x:Key="OnboardingButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Margin" Value="0,0,0,0" />
    </Style>

    <!-- Windows 11 style ToggleSwitch for WPF ToggleButton -->
    <Style x:Key="WindowsNativeSwitchStyle" TargetType="ToggleButton">
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="20" />
        <Setter Property="MinWidth" Value="40" />
        <Setter Property="MinHeight" Value="20" />
        <Setter Property="Background" Value="#00000000" />
        <Setter Property="BorderBrush" Value="#8A929D" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Grid Width="{TemplateBinding Width}"
                          Height="{TemplateBinding Height}"
                          SnapsToDevicePixels="True">
                        <Border x:Name="SwitchTrack"
                                CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" />
                        <Ellipse x:Name="SwitchKnob"
                                 Width="12"
                                 Height="12"
                                 Fill="#8A929D"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Center"
                                 Margin="4,0,0,0" />
                    </Grid>
                    <ControlTemplate.Triggers>

                        <!-- ── Static color states (instant) ── -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="SwitchTrack" Property="Background" Value="#0F000000" />
                            <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="#6F7782" />
                            <Setter TargetName="SwitchKnob" Property="Fill" Value="#6F7782" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="#005FB8" />
                            <Setter TargetName="SwitchTrack" Property="BorderThickness" Value="2" />
                        </Trigger>
                        <!-- Press: grow knob slightly; Margin omitted — animation holds it -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="SwitchKnob" Property="Width" Value="14" />
                            <Setter TargetName="SwitchKnob" Property="Height" Value="14" />
                        </Trigger>
                        <!-- Checked: colors + knob slide via EnterActions/ExitActions -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="SwitchTrack" Property="Background" Value="#005FB8" />
                            <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="#005FB8" />
                            <Setter TargetName="SwitchKnob" Property="Fill" Value="White" />
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ThicknessAnimation Storyboard.TargetName="SwitchKnob"
                                                            Storyboard.TargetProperty="Margin"
                                                            To="24,0,0,0"
                                                            Duration="0:0:0.18">
                                            <ThicknessAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseInOut"/>
                                            </ThicknessAnimation.EasingFunction>
                                        </ThicknessAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ThicknessAnimation Storyboard.TargetName="SwitchKnob"
                                                            Storyboard.TargetProperty="Margin"
                                                            To="4,0,0,0"
                                                            Duration="0:0:0.18">
                                            <ThicknessAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseInOut"/>
                                            </ThicknessAnimation.EasingFunction>
                                        </ThicknessAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="SwitchTrack" Property="Background" Value="#004C99" />
                            <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="#004C99" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True" />
                                <Condition Property="IsPressed" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="SwitchTrack" Property="Background" Value="#003E7E" />
                            <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="#003E7E" />
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

