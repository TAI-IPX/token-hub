                                                    To="#B3FFFFFF" Duration="0:0:0.12"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                            <BeginStoryboard>
                                <Storyboard>
                                    <ColorAnimation Storyboard.TargetName="SecBg"
                                                    Storyboard.TargetProperty="Color"
                                                    To="#DEE2E9" Duration="0:0:0.06"/>
