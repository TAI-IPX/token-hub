<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Shadow Effects -->
    <!-- Win11 tray flyout shadow — unified with notification style -->
    <DropShadowEffect x:Key="PanelShadow"
                      BlurRadius="16"
                      ShadowDepth="8"
                      Direction="270"
                      Color="#0F172A"
                      Opacity="0.16" />
    <DropShadowEffect x:Key="MenuShadow"
                      BlurRadius="8"
                      ShadowDepth="4"
                      Direction="270"
                      Color="#000000"
                      Opacity="0.14" />
    <DropShadowEffect x:Key="NotificationShadow"
                      BlurRadius="12"
                      ShadowDepth="12"
                      Direction="270"
                      Color="#0F172A"
                      Opacity="0.16" />
    <DropShadowEffect x:Key="ToggleKnobShadow"
                      BlurRadius="2"
                      ShadowDepth="1"
                      Direction="270"
                      Color="#000000"
                      Opacity="0.20" />

    <!-- Accent Colors -->
    <Color x:Key="AccentColor">#005FB8</Color>
    <Color x:Key="AccentHoverColor">#004C99</Color>
    <Color x:Key="AccentPressedColor">#003E7E</Color>
    <Color x:Key="AccentSoftColor">#EAF3FF</Color>

    <!-- Text Colors -->
    <Color x:Key="TextPrimaryColor">#1B1B1F</Color>
    <Color x:Key="TextSecondaryColor">#5E626A</Color>
    <Color x:Key="TextTertiaryColor">#7B8088</Color>

    <!-- Surface Colors -->
    <Color x:Key="SurfaceBaseColor">#F8FBFF</Color>
    <Color x:Key="SurfaceTitleBarColor">#F6F8FC</Color>
    <Color x:Key="SurfaceControlColor">#FFFFFF</Color>
    <Color x:Key="SurfaceHoverColor">#EEF1F6</Color>
    <Color x:Key="SurfacePressedColor">#DEE2E9</Color>

    <!-- Border Colors -->
    <Color x:Key="StrokeSubtleColor">#14000000</Color>
    <Color x:Key="StrokeCardColor">#2E000000</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource AccentSoftColor}" />

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiaryColor}" />

    <SolidColorBrush x:Key="SurfaceBaseBrush" Color="{StaticResource SurfaceBaseColor}" />
    <SolidColorBrush x:Key="SurfaceTitleBarBrush" Color="{StaticResource SurfaceTitleBarColor}" />
    <SolidColorBrush x:Key="SurfaceControlBrush" Color="{StaticResource SurfaceControlColor}" />
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="{StaticResource SurfaceHoverColor}" />
    <SolidColorBrush x:Key="SurfacePressedBrush" Color="{StaticResource SurfacePressedColor}" />

    <SolidColorBrush x:Key="StrokeSubtleBrush" Color="{StaticResource StrokeSubtleColor}" />
    <SolidColorBrush x:Key="StrokeCardBrush" Color="{StaticResource StrokeCardColor}" />

    <SolidColorBrush x:Key="ToggleOffBrush" Color="#8A929D" />
    <SolidColorBrush x:Key="ToggleOnBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="GreenTagBrush" Color="#16A34A" />
    <SolidColorBrush x:Key="WarningBrush" Color="#B42318" />
    <SolidColorBrush x:Key="WarningBgBrush" Color="#FFE4E1" />
    <SolidColorBrush x:Key="LowBalanceBrush" Color="#8A5700" />
    <SolidColorBrush x:Key="LowBalanceBgBrush" Color="#FFF0C2" />
    <SolidColorBrush x:Key="NewTagBgBrush" Color="#DFF7E9" />
    <SolidColorBrush x:Key="NewTagBrush" Color="#08783D" />
    <SolidColorBrush x:Key="SmartModeBgBrush" Color="#F2F4FC" />
    <SolidColorBrush x:Key="AccentTagBgBrush" Color="#E8F3FF" />
    <SolidColorBrush x:Key="AccentTagBrush" Color="#176FC4" />
    <SolidColorBrush x:Key="FooterBgBrush" Color="#F6F8FC" />

    <!-- Dimensions -->
    <sys:Double x:Key="PanelWidth">360</sys:Double>
    <sys:Double x:Key="PanelHeightNormal">384</sys:Double>
    <sys:Double x:Key="PanelHeightCompact">318</sys:Double>
    <sys:Double x:Key="TitleBarHeight">48</sys:Double>
    <sys:Double x:Key="FooterHeight">64</sys:Double>
    <sys:Double x:Key="ListItemHeight">48</sys:Double>
    <sys:Double x:Key="ModelItemHeight">80</sys:Double>
    <sys:Double x:Key="AppIconSize">28</sys:Double>
    <sys:Double x:Key="AvatarSize">28</sys:Double>
    <sys:Double x:Key="RechargeButtonWidth">80</sys:Double>
    <sys:Double x:Key="RechargeButtonHeight">32</sys:Double>
    <sys:Double x:Key="ToggleWidth">42</sys:Double>
    <sys:Double x:Key="ToggleHeight">22</sys:Double>
    <sys:Double x:Key="KnobSize">16</sys:Double>
    <sys:Double x:Key="RadioSize">20</sys:Double>
    <sys:Double x:Key="CornerRadius">8</sys:Double>
    <sys:Double x:Key="ControlCornerRadius">4</sys:Double>
    <sys:Double x:Key="TagHeight">16</sys:Double>
    <sys:Double x:Key="SmartModeHeight">56</sys:Double>
    <CornerRadius x:Key="PanelCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="ControlCornerRadiusObj">4</CornerRadius>

    <!-- Font -->
    <FontFamily x:Key="DefaultFont">Microsoft YaHei</FontFamily>
    <sys:Double x:Key="DefaultFontSize">14</sys:Double>

</ResourceDictionary>
