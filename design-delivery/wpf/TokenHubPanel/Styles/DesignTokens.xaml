<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Shadow Effects -->
    <!-- Win11 tray flyout shadow — unified with notification style -->
    <DropShadowEffect x:Key="PanelShadow"
                      BlurRadius="16"
                      ShadowDepth="8"
                      Direction="270"
                      Color="#0F172A"
                      Opacity="0.16" />
    <DropShadowEffect x:Key="MenuShadow"
                      BlurRadius="12"
                      ShadowDepth="4"
                      Direction="270"
                      Color="#000000"
                      Opacity="0.12" />
    <DropShadowEffect x:Key="NotificationShadow"
                      BlurRadius="16"
                      ShadowDepth="8"
                      Direction="270"
                      Color="#000000"
                      Opacity="0.16" />
    <!-- Win11 confirm dialog shadow — very subtle, tight fit -->
    <DropShadowEffect x:Key="ConfirmDialogShadow"
                      BlurRadius="12"
                      ShadowDepth="4"
                      Direction="270"
                      Color="#000000"
                      Opacity="0.12" />
    <!-- Figma 632:641 tray context menu shadow -->
    <DropShadowEffect x:Key="TrayMenuShadow"
                      BlurRadius="12"
                      ShadowDepth="4"
                      Direction="270"
                      Color="#000000"
                      Opacity="0.12" />
    <DropShadowEffect x:Key="ToggleKnobShadow"
                      BlurRadius="2"
                      ShadowDepth="1"
                      Direction="270"
                      Color="#000000"
                      Opacity="0.20" />

    <!-- Accent Colors -->
    <Color x:Key="AccentColor">#005FB8</Color>
    <Color x:Key="AccentHoverColor">#004C99</Color>
    <Color x:Key="AccentPressedColor">#003E7E</Color>
    <Color x:Key="AccentSoftColor">#EAF3FF</Color>

    <!-- Text Colors -->
    <Color x:Key="TextPrimaryColor">#1B1B1F</Color>
    <Color x:Key="TextSecondaryColor">#5E626A</Color>
    <Color x:Key="TextTertiaryColor">#7B8088</Color>

    <!-- Surface Colors -->
    <Color x:Key="SurfaceBaseColor">#F8FBFF</Color>
    <Color x:Key="SurfaceTitleBarColor">#F6F8FC</Color>
    <Color x:Key="SurfaceControlColor">#FFFFFF</Color>
    <Color x:Key="SurfaceHoverColor">#EEF1F6</Color>
    <Color x:Key="SurfacePressedColor">#DEE2E9</Color>

    <!-- Border Colors -->
    <Color x:Key="StrokeSubtleColor">#14000000</Color>
    <Color x:Key="StrokeCardColor">#2E000000</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource AccentSoftColor}" />

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiaryColor}" />

    <SolidColorBrush x:Key="SurfaceBaseBrush" Color="{StaticResource SurfaceBaseColor}" />
    <SolidColorBrush x:Key="SurfaceTitleBarBrush" Color="{StaticResource SurfaceTitleBarColor}" />
    <SolidColorBrush x:Key="SurfaceControlBrush" Color="{StaticResource SurfaceControlColor}" />
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="{StaticResource SurfaceHoverColor}" />
    <SolidColorBrush x:Key="SurfacePressedBrush" Color="{StaticResource SurfacePressedColor}" />

    <SolidColorBrush x:Key="StrokeSubtleBrush" Color="{StaticResource StrokeSubtleColor}" />
    <SolidColorBrush x:Key="StrokeCardBrush" Color="{StaticResource StrokeCardColor}" />

    <SolidColorBrush x:Key="ToggleOffBrush" Color="#8A929D" />
    <SolidColorBrush x:Key="ToggleOnBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="GreenTagBrush" Color="#16A34A" />
    <SolidColorBrush x:Key="WarningBrush" Color="#B42318" />
    <SolidColorBrush x:Key="WarningBgBrush" Color="#FFE4E1" />
    <SolidColorBrush x:Key="LowBalanceBrush" Color="#8A5700" />
    <SolidColorBrush x:Key="LowBalanceBgBrush" Color="#FFF0C2" />
    <SolidColorBrush x:Key="NewTagBgBrush" Color="#DFF7E9" />
    <SolidColorBrush x:Key="NewTagBrush" Color="#08783D" />
    <SolidColorBrush x:Key="SmartModeBgBrush" Color="#F2F4FC" />
    <SolidColorBrush x:Key="AccentTagBgBrush" Color="#E8F3FF" />
    <SolidColorBrush x:Key="AccentTagBrush" Color="#176FC4" />
    <SolidColorBrush x:Key="FooterBgBrush" Color="#F6F8FC" />

    <!-- Notification tokens: source Figma node 673:9093, Frame 001/Frame 002 -->
    <Color x:Key="NotificationSurfaceColor">#F3F3F3</Color>
    <Color x:Key="NotificationSurfaceHoverColor">#EFEFEF</Color>
    <Color x:Key="NotificationStrokeColor">#66757575</Color>
    <Color x:Key="NotificationTitleTextColor">#000000</Color>
    <Color x:Key="NotificationBodyTextColor">#99000000</Color>
    <Color x:Key="NotificationIconButtonTextColor">#991B1B1F</Color>
    <Color x:Key="NotificationIconButtonHoverColor">#0D000000</Color>
    <Color x:Key="NotificationIconButtonPressedColor">#14000000</Color>
    <Color x:Key="NotificationTagBackgroundColor">#CFE3F3</Color>
    <Color x:Key="NotificationTagTextColor">#005FB8</Color>
    <SolidColorBrush x:Key="NotificationSurfaceBrush" Color="{StaticResource NotificationSurfaceColor}" />
    <SolidColorBrush x:Key="NotificationSurfaceHoverBrush" Color="{StaticResource NotificationSurfaceHoverColor}" />
    <SolidColorBrush x:Key="NotificationStrokeBrush" Color="{StaticResource NotificationStrokeColor}" />
    <SolidColorBrush x:Key="NotificationTitleTextBrush" Color="{StaticResource NotificationTitleTextColor}" />
    <SolidColorBrush x:Key="NotificationBodyTextBrush" Color="{StaticResource NotificationBodyTextColor}" />
    <SolidColorBrush x:Key="NotificationIconButtonTextBrush" Color="{StaticResource NotificationIconButtonTextColor}" />
    <SolidColorBrush x:Key="NotificationIconButtonHoverBrush" Color="{StaticResource NotificationIconButtonHoverColor}" />
    <SolidColorBrush x:Key="NotificationIconButtonPressedBrush" Color="{StaticResource NotificationIconButtonPressedColor}" />
    <SolidColorBrush x:Key="NotificationTagBackgroundBrush" Color="{StaticResource NotificationTagBackgroundColor}" />
    <SolidColorBrush x:Key="NotificationTagTextBrush" Color="{StaticResource NotificationTagTextColor}" />

    <!-- Dimensions -->
    <sys:Double x:Key="PanelWidth">360</sys:Double>
    <sys:Double x:Key="PanelHeightNormal">384</sys:Double>
    <sys:Double x:Key="PanelHeightCompact">318</sys:Double>
    <sys:Double x:Key="TitleBarHeight">48</sys:Double>
    <sys:Double x:Key="FooterHeight">64</sys:Double>
    <sys:Double x:Key="ListItemHeight">48</sys:Double>
    <sys:Double x:Key="ModelItemHeight">80</sys:Double>
    <sys:Double x:Key="AppIconSize">28</sys:Double>
    <sys:Double x:Key="AvatarSize">28</sys:Double>
    <sys:Double x:Key="RechargeButtonWidth">80</sys:Double>
    <sys:Double x:Key="RechargeButtonHeight">32</sys:Double>
    <sys:Double x:Key="ToggleWidth">42</sys:Double>
    <sys:Double x:Key="ToggleHeight">22</sys:Double>
    <sys:Double x:Key="KnobSize">16</sys:Double>
    <sys:Double x:Key="RadioSize">20</sys:Double>
    <sys:Double x:Key="CornerRadius">8</sys:Double>
    <sys:Double x:Key="ControlCornerRadius">4</sys:Double>
    <sys:Double x:Key="TagHeight">16</sys:Double>
    <sys:Double x:Key="SmartModeHeight">56</sys:Double>
    <sys:Double x:Key="NotificationCardWidth">360</sys:Double>
    <sys:Double x:Key="NotificationCardHeight">113</sys:Double>
    <sys:Double x:Key="NotificationAppIconSize">20</sys:Double>
    <sys:Double x:Key="NotificationIconButtonSize">16</sys:Double>
    <sys:Double x:Key="NotificationIconImageSize">16</sys:Double>
    <sys:Double x:Key="NotificationTitleFontSize">16</sys:Double>
    <sys:Double x:Key="NotificationTitleLineHeight">26</sys:Double>
    <sys:Double x:Key="NotificationBodyFontSize">14</sys:Double>
    <sys:Double x:Key="NotificationBodyLineHeight">22</sys:Double>
    <sys:Double x:Key="NotificationTagFontSize">11</sys:Double>
    <sys:Double x:Key="NotificationTagLineHeight">11</sys:Double>
    <sys:Double x:Key="NotificationTagHeight">17</sys:Double>
    <sys:Double x:Key="NotificationEntranceOffset">8</sys:Double>
    <CornerRadius x:Key="PanelCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="ControlCornerRadiusObj">4</CornerRadius>
    <CornerRadius x:Key="NotificationCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="NotificationTagCornerRadius">2</CornerRadius>
    <Thickness x:Key="NotificationContentMargin">15,9,11,22</Thickness>
    <Thickness x:Key="NotificationTextColumnMargin">13,7,0,0</Thickness>
    <Thickness x:Key="NotificationActionButtonMargin">0,0,0,0</Thickness>
    <Thickness x:Key="NotificationFirstActionButtonMargin">0,0,8,0</Thickness>
    <Thickness x:Key="NotificationBodyTextMargin">0,0,0,0</Thickness>
    <Thickness x:Key="NotificationTagListMargin">0,8,0,0</Thickness>
    <Thickness x:Key="NotificationTagPadding">4,3</Thickness>
    <Thickness x:Key="NotificationTagMargin">0,0,8,0</Thickness>

    <!-- Motion: hover/press durations for XAML storyboards (code-behind scale lives in Anim.cs) -->
    <Duration x:Key="MotionHover">0:0:0.12</Duration>
    <Duration x:Key="MotionPress">0:0:0.06</Duration>

    <!-- Font -->
    <FontFamily x:Key="DefaultFont">Microsoft YaHei</FontFamily>
    <sys:Double x:Key="DefaultFontSize">14</sys:Double>

</ResourceDictionary>
