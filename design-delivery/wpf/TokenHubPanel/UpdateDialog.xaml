<Window x:Class="TokenHubPanel.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="联想 Token Hub"
        FontFamily="Microsoft YaHei"
        FontSize="14"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        Topmost="True"
        MouseDown="Window_MouseDown">
    <Window.Resources>
        <DropShadowEffect x:Key="UpdateWindowShadow1"
                          BlurRadius="21"
                          ShadowDepth="2"
                          Direction="270"
                          Color="#000000"
                          Opacity="0.22" />
    </Window.Resources>

    <Border Width="560" Height="400"
            CornerRadius="7"
            Background="#F3F3F3"
            BorderBrush="#66757575"
            BorderThickness="1"
            Effect="{StaticResource UpdateWindowShadow1}"
            Margin="32">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Height="48" Padding="12,0,8,0" Background="Transparent">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: Icon + Title -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="Assets/dialog-brand@3x.png"
                               Width="24" Height="24"
                               Margin="0,0,8,0" />
                        <TextBlock Text="联想 TokenHub"
                                   FontSize="12"
                                   FontWeight="Regular"
                                   Foreground="#E51B1B1F"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Min / Max / Close -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <!-- Minimize -->
                        <Button Width="32" Height="32"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Click="MinimizeButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="4" Background="Transparent">
                                        <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="10" Foreground="#E5000000"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#0A000000" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <!-- Close -->
                        <Button Width="32" Height="32"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Click="CloseButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="4" Background="Transparent">
                                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="10" Foreground="#E5000000"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#0A000000" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Update Info -->
                <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,32,0,32">
                    <!-- Icon from Figma -->
                    <Image Source="Assets/dialog-update-icon@3x.png"
                           Width="48" Height="48"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20" />

                    <!-- Title -->
                    <TextBlock Text="发现新版本"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#E0000000"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8" />

                    <!-- Description -->
                    <TextBlock Text="{Binding UpdateDescription, StringFormat='Token Hub {0} 可用，建议更新以获得最新适配和体验优化。'}"
                               FontSize="14"
                               Foreground="#99000000"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               MaxWidth="390" />
                </StackPanel>

                <!-- Buttons (available state) -->
                <StackPanel x:Name="ButtonsPanel"
                            Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,24">
                    <Button Content="稍后"
                            Width="200"
                            Height="32"
                            FontSize="14"
                            Foreground="#E5000000"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="LaterButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd"
                                        Background="#E6F0F0F0"
                                        BorderBrush="#1A000000"
                                        BorderThickness="1"
                                        CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#D0F0F0F0" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="UpdateButton"
                            Content="立即更新"
                            Width="200"
                            Height="32"
                            FontSize="14"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="8,0,0,0"
                            Click="UpdateButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd"
                                        Background="#005FB8"
                                        BorderBrush="#14FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#004C99" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <!-- Progress (updating state) -->
                <StackPanel x:Name="ProgressPanel"
                            Grid.Row="1"
                            Visibility="Collapsed"
                            Margin="24,0,24,24">
                    <TextBlock x:Name="ProgressText"
                               Text="正在更新 67%"
                               FontSize="14"
                               Foreground="#99000000"
                               Margin="0,0,0,16" />
                    <Grid Height="32">
                        <Border Height="1" CornerRadius="99"
                                Background="#99000000"
                                VerticalAlignment="Center" />
                        <Border x:Name="ProgressTrack"
                                Height="3" CornerRadius="99"
                                Background="#005FB8"
                                Width="348"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
