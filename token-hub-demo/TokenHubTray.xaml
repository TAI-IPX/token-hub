<!-- TokenHubTray.xaml
     WPF 托盘面板设计还原 — 完全匹配 Web Demo (df80e43)
     目标框架: .NET 8.0 WPF
     用法: 作为独立 Window 或嵌入 Popup/Flyout 使用
-->
<Window x:Class="TokenHub.TrayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="联想 Token Hub"
        Width="440" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True">

    <Window.Resources>
        <!-- ===== Design Tokens ===== -->
        <Color x:Key="AccentColor">#005FB8</Color>
        <Color x:Key="AccentHoverColor">#004C99</Color>
        <Color x:Key="AccentPressedColor">#003E7E</Color>
        <Color x:Key="TextPrimaryColor">#1B1B1F</Color>
        <Color x:Key="TextSecondaryColor">#5E626A</Color>
        <Color x:Key="TextTertiaryColor">#7B8088</Color>
        <Color x:Key="SurfaceBaseColor">#F8FBFF</Color>
        <Color x:Key="StrokeCardColor">#2E000000</Color>
        <Color x:Key="DividerColor">#A3D9DEE8</Color>
        <Color x:Key="TagGreenColor">#16A34A</Color>
        <Color x:Key="TagGreenBgColor">#5CFFFFFF</Color>
        <Color x:Key="TagDangerColor">#DC2626</Color>
        <Color x:Key="TagDangerBgColor">#1FDC2626</Color>

        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
        <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiaryColor}" />
        <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource DividerColor}" />

        <!-- Panel Acrylic Background (simulated; real AcrylicBrush needs WinUI/WindowsComposition) -->
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#F0F8FBFF" />
        <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#70F6F8FC" />

        <!-- ===== Typography ===== -->
        <FontFamily x:Key="AppFont">Microsoft YaHei</FontFamily>

        <!-- ===== Toggle Switch Style ===== -->
        <Style x:Key="ToggleSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="Track" CornerRadius="11"
                                    Background="#CCCCCC" />
                            <Border x:Name="Knob" Width="16" Height="16"
                                    CornerRadius="8" Background="White"
                                    HorizontalAlignment="Left" Margin="3,0,0,0">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="2" ShadowDepth="1" Opacity="0.2" Direction="270" />
                                </Border.Effect>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#0067C0" />
                                <Setter TargetName="Knob" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="Knob" Property="Margin" Value="0,0,3,0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Icon Button Style ===== -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="20" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.7" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ===== App List Item Template ===== -->
        <DataTemplate x:Key="AppListItemTemplate">
            <Button Style="{x:Null}" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate>
                        <Border x:Name="ItemBorder" Height="48" CornerRadius="4"
                                Background="Transparent" Padding="16,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- App Icon + Name -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Border Width="28" Height="28" CornerRadius="6"
                                            Background="#EAF3FF">
                                        <Image Source="{Binding Icon}" Width="28" Height="28"
                                               Stretch="UniformToFill" />
                                    </Border>
                                    <TextBlock Text="{Binding Name}" FontSize="14"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               VerticalAlignment="Center" Margin="12,0,0,0" />
                                </StackPanel>

                                <!-- Model Name + Chevron -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding ModelName}" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center" />
                                    <Image Source="assets/3x/icon-chevron-right@3x.svg"
                                           Width="20" Height="20" Margin="8,0,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background"
                                        Value="#08000000" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </DataTemplate>

        <!-- ===== Model List Item Template (Detail Page) ===== -->
        <DataTemplate x:Key="ModelListItemTemplate">
            <Border Height="72" CornerRadius="4" Background="Transparent" Padding="20,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Radio + Content -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <RadioButton GroupName="ModelSelection" IsChecked="{Binding IsSelected}"
                                     Width="20" Height="20" VerticalAlignment="Center" />
                        <StackPanel Margin="20,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Bold"
                                       Foreground="#E0000000" />
                            <TextBlock Text="{Binding PriceLine}" FontSize="12" Margin="0,4,0,0"
                                       Foreground="#99000000" />
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <ItemsControl ItemsSource="{Binding Tags}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Height="16" CornerRadius="4" Padding="4,0"
                                                    Background="{StaticResource TagGreenBgColor}"
                                                    Margin="0,0,4,0">
                                                <TextBlock Text="{Binding}" FontSize="10"
                                                           Foreground="#16A34A"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Badge -->
                    <TextBlock Grid.Column="2" Text="当前模型" FontSize="11"
                               Foreground="#2563EB" VerticalAlignment="Center"
                               Visibility="{Binding BadgeVisibility}" />
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <!-- ===== MAIN PANEL ===== -->
    <Border CornerRadius="8"
            BorderBrush="#2E000000" BorderThickness="1"
            Background="{StaticResource PanelBackgroundBrush}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="46" ShadowDepth="22" Direction="270"
                              Color="#0F172A" Opacity="0.22" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />   <!-- Title Bar -->
                <RowDefinition Height="*" />    <!-- Content (scrollable) -->
                <RowDefinition Height="64" />   <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- ===== TITLE BAR ===== -->
            <Border Grid.Row="0" Background="{StaticResource TitleBarBackgroundBrush}"
                    Padding="16,0,16,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Brand Group -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Image Source="assets/3x/panel-logo@3x.png"
                               Width="24" Height="24" />
                        <TextBlock Text="联想 TokenHub" FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="8,0,0,0" />
                        <!-- Dropdown button -->
                        <Button Style="{StaticResource IconButtonStyle}" Width="16" Height="16"
                                Margin="8,0,0,0" ToolTip="应用菜单">
                            <Path Data="M5.2 7.5 10 12.3 14.8 7.5 15.8 8.5 10.5 14C10.2 14.3 9.8 14.3 9.5 14L4.2 8.5Z"
                                  Fill="#9C000000" Width="12" Height="12" Stretch="Uniform" />
                        </Button>
                    </StackPanel>

                    <!-- Window Controls -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                VerticalAlignment="Center" HorizontalAlignment="Right">
                        <Button Style="{StaticResource IconButtonStyle}" ToolTip="设置"
                                Margin="0,0,16,0">
                            <Image Source="assets/3x/panel-settings@3x.png"
                                   Width="20" Height="20" />
                        </Button>
                        <Button Style="{StaticResource IconButtonStyle}" ToolTip="关闭">
                            <Image Source="assets/3x/panel-close@3x.png"
                                   Width="20" Height="20" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== SCROLLABLE CONTENT ===== -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="0,8,0,8">
                <StackPanel>
                    <!-- Smart Match Section (56px) -->
                    <Border Height="56" Padding="16,0">
                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="智能模型匹配" FontSize="14" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="按应用特性自动选择模型" FontSize="12" Margin="0,2,0,0"
                                           Foreground="#99000000" />
                            </StackPanel>

                            <ToggleButton Grid.Column="1"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          IsChecked="{Binding SmartMode}"
                                          VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <!-- App List Header (48px) -->
                    <Border Height="48" Padding="16,0">
                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="应用列表"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="#E0000000" />
                            <Button Grid.Column="1" Style="{StaticResource IconButtonStyle}"
                                    ToolTip="重新检测应用">
                                <Image Source="assets/3x/icon-action@3x.svg"
                                       Width="16" Height="16" />
                            </Button>
                        </Grid>
                    </Border>

                    <!-- App List Items -->
                    <ItemsControl ItemsSource="{Binding Tools}"
                                  ItemTemplate="{StaticResource AppListItemTemplate}" />
                </StackPanel>
            </ScrollViewer>

            <!-- ===== FOOTER (Account Bar) ===== -->
            <Border Grid.Row="2" Padding="16,0">
                <!-- Top Divider -->
                <Border.BorderBrush>
                    <SolidColorBrush Color="{StaticResource DividerColor}" />
                </Border.BorderBrush>
                <Border.BorderThickness>0,1,0,0</Border.BorderThickness>

                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Avatar + Account Info -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Ellipse Width="28" Height="28">
                            <Ellipse.Fill>
                                <ImageBrush ImageSource="assets/3x/avatar@3x.png"
                                            Stretch="UniformToFill" />
                            </Ellipse.Fill>
                        </Ellipse>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="159*****788" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="可用额度 ¥22.50" FontSize="12" Margin="0,2,0,0"
                                       Foreground="#99000000" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Actions -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Style="{StaticResource IconButtonStyle}" ToolTip="更多">
                            <Image Source="assets/3x/icon-more@3x.svg"
                                   Width="20" Height="20" />
                        </Button>
                        <Button Width="80" Height="32" Margin="12,0,0,0"
                                Background="{StaticResource AccentBrush}"
                                Foreground="White" FontSize="14"
                                Cursor="Hand" ToolTip="充值">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="BtnBorder" CornerRadius="4"
                                            Background="{StaticResource AccentBrush}"
                                            BorderBrush="#14FFFFFF" BorderThickness="1">
                                        <TextBlock Text="充值" FontSize="14" Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="BtnBorder" Property="Background"
                                                    Value="{StaticResource AccentHoverBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
